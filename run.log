	/**
	* Tests basic searching on a single case
	*
	* NOTES:  Because of how testing for SOSL works (err, doesn't work) we
	*  cannot truly test it.  SOSL tests require that you set a
	*  "FixedSearchResult" set.  These will always be your results even if they
	*  dont NOT match the given SOSL search.  So, because of this, all we cannot
	*  do any real negative testing or even testing if it returns one result and
	*  not another.
	*/
	static testMethod void searchTermsTooShort() {
		String needle = 'j';
		String ssoName = TestUtils.getUniqueString('_unittest_contact: sso');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount, testContact);
		testCase.Description = 'This is a needle '+needle+' in a haystack';
		insert testCase;

		List<Id> fixedSearchResults = new List<Id>();
		Test.setFixedSearchResults(fixedSearchResults);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.SearchContext sContext = new APIUtils.SearchContext(needle);


		Test.startTest();

		APIUtils.APICases result = CaseAPI.search(cContext, sContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_BAD, result.returnCode, 'Did not get the right status back');
		System.assertEquals(GenericUtils.MSG_SHORT_SEARCHSTRING, result.message, 'Did not get the right status message back ['+result.message+']');
		System.assert(result.cases.isEmpty(), 'Did not expect any cases back');
	}

