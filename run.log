				System.assertEquals(testTranscript.endedBy, transcript.endedBy, 'Ended By does not match');
				System.assertEquals(testTranscript.Contact.Name, transcript.visitorName, 'Visitor name does not match');
				System.assertEquals(testTranscript.Owner.Name, transcript.agentName, 'Agent name does not match');
			} else {
				System.assert(false, 'Got a transcript back we did not expect');
			}
		}

		System.assert(gotLiveAgent, 'Did not get the live agent transcript');
		System.assert(gotBomgar, 'Did not get the bomgar transcript');
	}

