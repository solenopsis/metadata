	static testMethod void addAttachmentsTest() {
		String testSsoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, testSsoName);
		insert testContact;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext testCContext = new APIUtils.ContactContext(testSsoName);

		APIUtils.APIAttachments apiAttachments = new APIUtils.APIAttachments();

		Integer numberOfAttachments = 1;

		for (Integer i = 0; i < numberOfAttachments; i++) {
			APIUtils.APIAttachment apiAttachment = new APIUtils.APIAttachment();

			String fileName = 'Test ' + i;
			apiAttachment.caseNumber = testCase.caseNumber;
			apiAttachment.fileName = fileName;
			apiAttachment.link = '_unittest_attachment_link_: 001';
			apiAttachment.description = 'Description: ' + i;
			apiAttachment.size = 4028;
			apiAttachment.sizeKB = 4;

			apiAttachments.addAPIAttachment(apiAttachment);
		}

		Test.startTest();

		APIUtils.APIAttachments result = CaseAPI.addAttachments(testCContext, apiAttachments);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back [' + result.message + ']');

		List<APIUtils.APIAttachment> returnedAPIAttachments = result.attachments;

		System.assertEquals(numberOfAttachments, returnedAPIAttachments.size(), 'The size of the returned APIAttachment list should be ' + numberOfAttachments);

		APIUtils.APIAttachment returnedAPIAttachment = returnedAPIAttachments.get(0);

		File_Attachment__c insertedAttachment = TestUtils.fetchAttachment(new File_Attachment__c(Id = returnedAPIAttachment.id));

		System.assertEquals(testCase.caseNumber, returnedAPIAttachment.caseNumber, 'The case number of the returned attachment is not we expected');
		System.assertEquals(insertedAttachment.Id, returnedAPIAttachment.id, 'The Id of the returned attachment is not we expected');
		System.assertEquals(insertedAttachment.Name, returnedAPIAttachment.fileName, 'The file name of the returned attachment is not we expected');
		System.assertEquals(insertedAttachment.Description__c, returnedAPIAttachment.description, 'The description of the returned attachment is not we expected');
		System.assertEquals(Long.valueOf(insertedAttachment.Size__c.replace(',','')), returnedAPIAttachment.size, 'The size of the returned attachment is not we expected');
		System.assertEquals(Double.valueOf(insertedAttachment.Size_in_KBs__c), returnedAPIAttachment.sizeKB, 'The sizeKB of the returned attachment is not we expected');
	}

