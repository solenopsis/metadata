	static testMethod void listCases_ITAR_internal_ignore_ITAR_case() {
		String ssoName = TestUtils.getUniqueString('_unittest_contact: sso');
		Set<String> expectedResults = new Set<String>();

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase1 = TestUtils.getCase(testAccount, testContact);
		testCase1 = TestUtils.setAsITARCase(testCase1);
		insert testCase1;

		Case testCase2 = TestUtils.getCase(testAccount, testContact);
		insert testCase2;

		expectedResults.add(testCase2.Subject);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);

		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();

		Test.startTest();

		APIUtils.APICases result =  CaseAPI.listCases(cContext, aContext, cFilter);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back [' + result.message + ']');
		System.AssertEquals(expectedResults.size(), result.cases.size(),'Did not get expected number of cases back');

		for (APIUtils.APICase kase : result.cases) {
			if (!expectedResults.contains(kase.summary)) {
				System.assert(false, 'Got a case back we did not expect [' + kase + ']');
			}
			expectedResults.remove(kase.summary);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the cases we expected [' + expectedResults + ']');
	}

