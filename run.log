	static testMethod void listCases_filter_commentId_multi_diffCase_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase1 = TestUtils.getCase(testAccount);
		insert testCase1;

		Case testCase2 = TestUtils.getCase(testAccount);
		insert testCase2;

		testCase1 = TestUtils.fetchCase(testCase1);
		testCase2 = TestUtils.fetchCase(testCase2);

		Case_Comment__c testComment1 = TestUtils.getPublicComment(testCase1);
		Case_Comment__c testComment2 = TestUtils.getPublicComment(testCase2);

		List<Case_Comment__c> testComments = new List<Case_Comment__c>{testComment1, testComment2};
		insert testComments;

		for (Case_Comment__c c : testComments) {
			if (c.Case__c == testCase1.Id) {
				testComment1 = c;
			} else if (c.Case__c == testCase2.Id) {
				testComment2 = c;
			}
		}

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();
		cFilter.commentIds = new List<Id>{testComment1.Id, testComment2.Id};

		Test.startTest();

		APIUtils.APICases results = CaseAPI.listCases(cContext, aContext, cFilter);

		Test.stopTest();

		Map<Id, Set<Id>> expectedResults = new Map<Id, Set<Id>>{
			testCase1.Id => new Set<Id>{testComment1.Id},
			testCase2.Id => new Set<Id>{testComment2.Id}
		};

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right status back ['+results.message+']');
		System.assertEquals(2, results.cases.size(), 'Did not get the right number of cases back');

		for (APIUtils.APICase c : results.cases) {
			System.assert(expectedResults.keySet().contains(c.Id), 'Got a case we did not expect [' + c.summary + ']');
			System.assertEquals(expectedResults.get(c.Id).size(), c.comments.size(), 'Did not get the right number of comments back. [' + c.summary + ']');

			for (APIUtils.APIComment comment : c.comments) {
				System.assert(expectedResults.get(c.Id).contains(comment.Id), 'Got a comment we did not expect [' + comment.text + ']');
				expectedResults.get(c.Id).remove(comment.Id);
			}

			expectedResults.remove(c.Id);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all expected comments [' + expectedResults + ']');
	}

