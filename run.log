	static testMethod void listCaseComments_single_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Case_Comment__c testComment = TestUtils.getPublicComment(testCase);
		insert testComment;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APIComments results = CaseAPI.listCaseComments(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(1, results.comments.size(), 'Did not get the right number of comments back');
		System.assertNotEquals(null, results.comments.get(0).text, 'The comment text should be null');
		System.assertEquals(testComment.Comment_Body__c, results.comments.get(0).text, 'Did not get the right comment back');
		System.assert(GenericUtils.isEmptyList(results.comments.get(0).sharePrivateWithExternalTrackers), 'Private partner map is [' + results.comments.get(0).sharePrivateWithExternalTrackers + '], should be empty');
	}

	static testMethod void listCaseComments_multi_valid() {
		Boolean isInternal = true;
		String commentBody1 = '_unittest_comment_: 001';
		String commentBody2 = '_unittest_comment_: 002';
		String commentBody3 = '_unittest_comment_: 003';
