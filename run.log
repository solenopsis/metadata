	static testMethod void listAllCases_noContactContext_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase1 = TestUtils.getCase(testAccount);
		testCase1.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;
		Case testCase2 = TestUtils.getCase(testAccount);
		testCase2.Status = GenericUtils.WAITING_ON_CUSTOMER_STATUS;
		Case testCase3 = TestUtils.getCase(testAccount);
		testCase3.Status = GenericUtils.CLOSED_STATUS;

		List<Case> testCases = new List<Case> {
			testCase1,
			testCase2,
			testCase3
		};
		insert testCases;

		Set<Id> expectedResults = new Set<Id> {
			testCase1.Id,
			testCase2.Id,
			testCase3.Id
		};

		APIUtils.ContactContext callingContext = new APIUtils.ContactContext(testContact);
		APIUtils.ContactContext contactContext = null;

		Test.startTest();

		APIUtils.APICases results = CaseAPI.listAllCases(callingContext, contactContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(expectedResults.size(), results.cases.size(), 'Did not get the right number of cases back');

		for (APIUtils.APICase result : results.cases) {
			System.assert(expectedResults.contains(result.Id), 'Got a result back we did not expect [' + result.summary + ']');
			expectedResults.remove(result.Id);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the results back ' + JSON.serialize(expectedResults));
	}

