		link1.resource = resource;
		link1.bucket = bucket;
		// link1.resourceViewURI = resourceViewUri;
		// link1.resourceURI = resourceURI;
		// link1.title = resourceTitle;
		link1.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
		link1.linked = true;

