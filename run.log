		etu = TestUtils.getExternalTrackerUpdate(testCase, externalTrackerUpdateBody2);
		etu.Originating_System_Last_Updated_At__c = DateTime.now().addDays(-6);
		testExternalTrackerUpdates.add(etu);

		etu = TestUtils.getExternalTrackerUpdate(testCase, externalTrackerUpdateBody3);
		etu.Originating_System_Last_Updated_At__c = DateTime.now().addDays(-2);
		testExternalTrackerUpdates.add(etu);

		User testUser = TestUtils.createStealthUser();

		System.runAs(testUser) {
			insert testExternalTrackerUpdates;
		}

		List<String> expectedBodies = new List<String> {
			externalTrackerUpdateBody3,
			externalTrackerUpdateBody1,
			externalTrackerUpdateBody2
		};

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
