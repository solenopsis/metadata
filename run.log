		apiAttachments.addAPIAttachment(attachment);

		delete testAttachment;

		DateTime now  = DateTime.now();
		Testutils.clearOutgoingMessages(now);

		Test.startTest();

		APIUtils.APIAttachments result = CaseAPI.updateAttachments(testCContext, apiAttachments);

		Test.stopTest();

		System.assertEquals(ApiUtils.STATUS_NOTFOUND, result.returnCode, 'Did not get expected returncode [' + result.message + ']');
		System.assert(result.message.contains(GenericUtils.MSG_UNKNOWN_ATTACHMENT_ID), 'Got right return code but wrong message');
		System.assert(result.attachments.isEmpty(), 'We should not have any attachment returned.');
	}

