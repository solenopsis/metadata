	static testMethod void updateCase_createLink_single_valid_with_internalContact() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Article__c testArticle = TestUtils.getDefaultArticle();
		insert testArticle;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		CaseFolder__c testGroup = TestUtils.getGroup(testAccount);
		insert testGroup;

		testGroup = TestUtils.fetchGroup(testGroup);

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getFullCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext context = new APIUtils.ContactContext(ssoName);
		APIUtils.APICase kase = new APIUtils.APICase();
		kase.caseNumber = testCase.CaseNumber;
		kase.alternateId = '_unittest_altid_: ' + String.valueOf(TestUtils.getRandomInteger(100000000));

		APIUtils.APICaseResourceLink link = new APIUtils.APICaseResourceLink(testArticle.KBase_URL__c);
		link.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
		link.origin = KCS_Link_Utils.ORIGIN_SEARCH;
		link.linked = true;

		kase.caseResourceLinks = new APIUtils.APICaseResourceLinks(new List<APIUtils.APICaseResourceLink> {link});

		Test.startTest();

		APIUtils.APICase result = CaseAPI.updateCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code [' + result.message + ']');

		List<KCS_Link__c> results = TestUtils.fetchKCSLinksForCase(testCase);

		System.assertEquals(1, results.size(), 'Did not get the right number of links back');
		System.assertEquals(testArticle.Id, results.get(0).Article__c, 'Did not get the right link back');
		System.assertEquals(KCS_Link_Utils.RELATIONSHIPTYPE_PIN, results.get(0).relationshipType__c, 'Did not get the correct relationship Type');
		System.assertEquals(null, results.get(0).linkingMechanism__c, 'Linking Mechanism is null');
		System.assertEquals(KCS_Link_Utils.PINNING_MECHANISM_STRATA, results.get(0).pinningMechanism__c, 'Pinning Mechanism is Strata');
		System.assertEquals(KCS_Link_Utils.ORIGIN_SEARCH, results.get(0).origin__c, 'Did not get the correct Origin');
	}

