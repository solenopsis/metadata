	static testMethod void removeCaseSBRs_single_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		List<String> onCaseSBRs = TestUtils.getActiveSBRs(2);

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase.SBR_Group__c = GenericUtils.joinMultiselectList(onCaseSBRs);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<String> toRemoveSBRs = new List<String>();
		toRemoveSBRS.add(onCaseSBRs.get(0));

		APIUtils.contactContext contactContext = new APIUtils.contactContext(testContact);
		APIUtils.caseContext caseContext = new APIUtils.caseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.removeCaseSBRs(contactContext, caseContext, toRemoveSBRs);

		Test.stopTest();

		Set<String> expectedResults = new Set<String>(onCaseSBRs);
		expectedResults.removeAll(toRemoveSBRs);

		System.assertEquals(APIUTils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.assertEquals(expectedResults.size(), result.sbrGroups.size(), 'Did not get the right number of SBRs back');

		for (String sbr : result.sbrGroups) {
			if (!expectedResults.contains(sbr)) {
				System.assert(false, 'Got an SBR we did not expect ['+sbr+']');
			}

			expectedResults.remove(sbr);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the results we expected ['+expectedResults+']');

		expectedResults = new Set<String>(onCaseSBRs);
		expectedResults.removeAll(toRemoveSBRs);

		testCase = TestUtils.fetchCase(testCase);

		for (String sbr : GenericUtils.splitMultiselectList(testCase.SBR_Group__c)) {
			if (!expectedResults.contains(sbr)) {
				System.assert(false, 'Got an SBR we did not expect ['+sbr+']');
			}

			expectedResults.remove(sbr);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the results we expected ['+expectedResults+']');
	}

