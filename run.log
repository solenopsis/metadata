	static testMethod void getCase_caseResourceLinksInPayload() {
		KCSSettingsUtils.CUSTOMER_REVEAL_DATE_FOR_TESTING = Date.today();

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount, testContact);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<Article__c> articleList = new List<Article__c>();
		articleList.add(TestUtils.getArticle('1 Article ' + DateTime.now().getTime()));
		articleList.add(TestUtils.getArticle('2 Article ' + DateTime.now().getTime()));
		articleList.add(TestUtils.getArticle('3 Article ' + DateTime.now().getTime()));
		articleList.add(TestUtils.getArticle('4 Article ' + DateTime.now().getTime()));
		articleList.add(TestUtils.getArticle('5 Article ' + DateTime.now().getTime()));
		articleList.add(TestUtils.getArticle('6 Article ' + DateTime.now().getTime()));

		for (Article__c article : articleList) {
			article.title__c = article.Name;
		}

		insert articleList;

		List<KCS_Link__c> kcsLinks = new List<KCS_Link__c>();
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(0).Id));
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(1).Id));
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(2).Id));
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(3).Id));
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(4).Id));
		kcsLinks.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(5).Id));

		String userNameAndSSOName = TestUtils.getEmailAddress('redhat.com');
		User testUser = TestUtils.createTseUser(userNameAndSSOName);
		System.runAs(testUser) {
			for (KCS_Link__c kcsLink : kcsLinks) {
				kcsLink.Relationship_Established_By__c = UserInfo.getUserId();
			}
		}

		DateTime linkedAtDate = DateTime.now();
		insert kcsLinks;

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(context, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');
		System.assertEquals(6, result.caseresourcelinks.size(), 'Did not get the right number of caseresourcelinks back');

		for (Integer i = 0; i < 6; i += 1) {
			Boolean article_is_seen = false;
			APIUtils.APICaseResourceLink caseResourceLink;
			String article_title_prefix = String.valueOf(i + 1) + ' Article';
			for (Integer j = 0; j < 6; j += 1) {
				if (result.caseresourcelinks.get(j).title.startswith(article_title_prefix)) {
					article_is_seen = true;
					caseResourceLink = result.caseresourcelinks.get(j);
				}
			}

			System.assert(article_is_seen, 'Did not get the right article back :: ' + article_title_prefix);
			System.assertEquals(GenericUtils.SOLUTION_RESOURCE + '/' + caseResourceLink.title, caseResourceLink.resourceURI, 'resourceURI set correctly');
			System.assertEquals(GenericUtils.VIEW_SOLUTION_RESOURCE + caseResourceLink.title, caseResourceLink.resourceViewURI, 'resourceViewURI set correctly');
			System.assertEquals(GenericUtils.AVALON_URL_MAP.get(GenericUtils.ENVIRONMENT) + testCase.CaseNumber, caseResourceLink.externalCaseURI, 'externalCaseURI set incorrectly');
			System.assertEquals(GenericUtils.ENVIRONMENT_URL + testCase.Id, caseResourceLink.caseURI, 'caseURI set incorrectly');
			System.assertEquals(testCase.CaseNumber, caseResourceLink.caseNumber, 'caseNumber set correctly');
			System.assertEquals(userNameAndSSOName, caseResourceLink.linkedBy, 'linkedBy set correctly');
			System.assertEquals(GenericUtils.MATURITY_LEVEL_PRODUCTION, caseResourceLink.maturityLevel, 'maturityLevel set correctly');
			System.assert(TestUtils.isWithinThreshold(15 * 1000, caseResourceLink.linkedAt.getTime(), linkedAtDate.getTime()), 'linkedAt within threshold');
			System.assertEquals(null, caseResourceLink.pinnedBy, 'pinnedBy is null');
			System.assertEquals(null, caseResourceLink.pinnedAt, 'pinnedAt is null');
			System.assertEquals(KCS_Link_Utils.ORIGIN_SEARCH, caseResourceLink.origin, 'origin is set to Search');
			System.assert(caseResourceLink.linked, 'linked is true');
		}
	}

