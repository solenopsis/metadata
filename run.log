	static testMethod void listAttachments_multi_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String fileName1 = '_unittest_name_: 001';
		String fileName2 = '_unittest_name_: 002';
		String fileName3 = '_unittest_name_: 003';

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<File_Attachment__c> testAttachments = new List<File_Attachment__c>();
		testAttachments.add(TestUtils.getPublicAttachment(testCase, fileName1));
		testAttachments.add(TestUtils.getPrivateAttachment(testCase, fileName2));
		testAttachments.add(TestUtils.getPublicAttachment(testCase, fileName3));
		insert testAttachments;

		Set<String> expectedNames = new Set<String>{fileName1, fileName3};
		Map<Id, File_Attachment__c> expectedResults = new Map<Id, File_Attachment__c>();
		for (File_Attachment__c attachment : testAttachments) {
			if (expectedNames.contains(attachment.name)) {
				expectedResults.put(attachment.Id, attachment);
			}
		}

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
		CaseAPI.AttachmentFilter attachmentFilter = null;

		Test.startTest();

		APIUtils.APIAttachments results = CaseAPI.listAttachments(contactContext, caseContext, attachmentFilter);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code ['+results.message+']');

		System.assertEquals(expectedResults.size(), results.attachments.size(), 'Did not get the expected number of attachments back');

		for (APIUtils.APIAttachment result : results.attachments) {
			if (!expectedResults.keySet().contains(result.Id)) {
				System.assert(false, 'Got an attachment we did not expect [' + result.fileName + ']');
			}

			File_Attachment__c attachment = expectedResults.get(result.Id);
			System.assertEquals(attachment.Name, result.fileName, 'Did not get the right file name back');
			expectedResults.remove(result.Id);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all of the expected results back [' + expectedResults + ']');
	}

