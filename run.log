	static testMethod void getCase_SBR_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		List<String> sbrs = TestUtils.getActiveSBRs(2);

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		testCase.SBR_Group__c = GenericUtils.joinMultiselectList(sbrs);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext callingContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(callingContext, caseContext);

		Test.stopTest();

		Set<String> expected = new Set<String>(sbrs);

		System.assertEquals(expected.size(), result.sbrGroups.size(), 'Did not get the right number SBRs back');

		for (String sbr : result.sbrGroups) {
			if (!expected.contains(sbr)) {
				System.assert(false, 'Got an SBR we did not expect ['+sbr+']');
			}

			expected.remove(sbr);
		}

		System.assert(expected.isEmpty(), 'We did not get all the SBRs back ['+expected+']');
	}

