	static testMethod void upsertCaseComment_insert_NEP_notLoC_valid() {
		Datetime NOW = Datetime.newInstanceGMT(2015, 1, 1, 0, 0, 0);
		Datetime INITIAL_RESPONSE_MILESTONE_TARGET_DATE = Datetime.newInstanceGMT(2014, 1, 1, 0, 0, 0);
		Datetime ONGOING_RESPONSE_MILESTONE_TARGET_DATE = Datetime.newInstanceGMT(2015, 2, 1, 0, 0, 0);
		Datetime NEP_TARGET_DATE = Datetime.newInstanceGMT(2016, 1, 1, 0, 0, 0);

		CaseTriggerBefore.SKIP_PRIORITY_SCORE_CALCULATION = true;
		CaseTriggerAfter.TARGET_DATE_LOCK = false;
		CaseTriggerAfter.USE_FUTURE_FOR_MILESTONES = false;

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;
		insert testCase;

		CaseMilestoneUtils.CASE_ID_TO_CASEMILESTONE_LIST.put(testCase.Id,
			new CaseMilestoneUtils.CaseMilestoneList(
				new List<CaseMilestoneUtils.CaseMilestoneWrapper> {
					TestUtils.getCompletedFirstResponseCMW(INITIAL_RESPONSE_MILESTONE_TARGET_DATE, testCase.id),
					TestUtils.getNonCompletedOngoingResponseCMW(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.Id)
				}
			)
		);

		Case_Comment__c firstComment = TestUtils.getPublicComment(testCase);
		insert firstComment;

		Negotiated_Entitlement_Process__c testNEP = TestUtils.createYearFromNowNEP(testCase, NOW);

		testCase.Status = GenericUtils.WAITING_ON_CUSTOMER_STATUS;
		testCase.Internal_Status__c = GenericUtils.WAITING_ON_CUSTOMER_ISTATUS;
		update testCase;

		testNEP = TestUtils.fetchNEP(testNEP);
		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(NEP_TARGET_DATE, testNEP.Target_Date__c, 'target date is unexpected');
		System.assertEquals(NEP_TARGET_DATE, testCase.TargetDate__c, 'target date should be nep date');

		Case_Comment__c testComment = TestUtils.getPublicComment(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.APIComment apiComment = new APIUtils.APIComment(testComment);
		apiComment.caseNumber = testCase.CaseNumber;

		CaseTriggerAfter.TARGET_DATE_LOCK = false;

		Test.startTest();
		APIUtils.APIComment result = CaseAPI.upsertCaseComment(contactContext, apiComment);
		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code back [' + result.message + ']');

		Case_Comment__c newComment = TestUtils.fetchComment(new Case_Comment__c(Id = result.Id));
		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(testCase.Id, newComment.Case__c, 'Did not get assigned to the right case');
		System.assertEquals(testComment.Comment_Body__c, newComment.Comment_Body__c, 'Did not get the right body back');
		System.assert(newComment.Is_Public__c, 'Did not get the right public status back');
		System.assert(!newComment.Is_Draft__c, 'Did not get the right draft status back');
		System.assertEquals(testContact.Id, newComment.Created_By_Contact__c, 'Did not get the right created by');
		System.assertEquals(GenericUtils.WAITING_ON_RED_HAT_STATUS, testCase.Status, 'Did not get the right status back');
		System.assertEquals(GenericUtils.WAITING_ON_OWNER_ISTATUS, testCase.Internal_Status__c, 'Did not get the right internal status back');

		testNEP = TestUtils.fetchNepForCase(testCase);
		System.assertEquals(null, testNEP, 'Case should not have a NEP after being updated by customer contact');

		System.assertEquals(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.TargetDate__c, 'target date should no longer be nep date');
	}

