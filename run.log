@isTest
private class CaseAPI_listType_Test {
	@TestSetup
	static void setUp() {
		TestUtils.setupProductAndVersion();
	}

	//////////////////////////////////////////////////////////////////////////
	//                             listType                                 //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void listType_valid() {
		Set<String> expectedResults = new Set<String>(GenericUtils.getPicklistLabels(Case.Type.getDescribe()));
		Set<String> knownResults = GenericUtils.KNOWN_TYPE;

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.listType(cContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(expectedResults.size(), results.values.size(), 'Did not get the right number of types back');

		for (String type : results.values) {
			System.assert(expectedResults.contains(type), 'Got a type we did not expect [' + type + ']');
			expectedResults.remove(type);
			knownResults.remove(type);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the types we expected [' + expectedResults + ']');
		System.assert(knownResults.isEmpty(), 'Did not get all the known types we expected [' + knownResults + ']');
	}

