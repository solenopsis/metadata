	// This method is a copy of CaseAPI.upsertCaseComment *except* just before upsert of the caseComment, it
	// runs CaseAPI.upsertCaseComment with a non-draft comment payload.
	private static APIUtils.APIComment upsertCaseComment(APIUtils.ContactContext contactContext, APIUtils.APIComment apiComment) {
		final List<Object> paramList = new List<Object> {contactContext, apiComment};
		final String methodName = 'upsertCaseComment';
		APIUtils.APIComment result = new APIUtils.APIComment();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(contactContext);

			Contact callingContact = AccountUtils.getContact(contactContext.ssoName);
			Boolean isInternal = AccountUtils.isInternal(callingContact);

			apiComment.setupComment(callingContact, isInternal);

			Case_Comment__c comment = null;

			if (GenericUtils.isEmpty(apiComment.Id)) {
				comment = apiComment.getNewComment();
			} else {
				comment = apiComment.getUpdateComment();
			}

			EmailManager.lockExternally();

			Case newCase = apiComment.getCase();
			String oldCaseStatus = newCase.Status;

			APIUtils.ensureEndpointAccess(contactContext, newCase);

			if ((CaseUtils.hasHoldSupport(newCase)) && (CaseCommentUtils.isPublic(comment))) {
				throw new GenericUtils.InvalidPermissionsException(APIUtils.HOLD_SUPPORT_ON_ACCOUNT_MSG);
			}

			if (!CaseCommentUtils.isDraft(comment)) {
				if (CaseCommentUtils.isPublic(comment)) {
					newCase.Last_Modified_By_Contact__c = callingContact.Id;
					newCase.Last_Modified_By_Id__c = callingContact.Id;
					newCase.Internal_Status__c = CaseUtils.getInternalStatusForWoRHChange(newCase, isInternal);
					newCase.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;

					update newCase;
				}
			}

			APIUtils.APIComment nonDraftAPIComment = (APIUtils.APIComment) JSON.deserializeStrict(
				JSON.serialize(apiComment),
				APIUtils.APIComment.class
			);
			nonDraftAPIComment.isDraft = false;
			nonDraftAPIComment.text = CaseAPI_upsertCaseComment_Test.NON_DRAFT_COMMENT_BODY;
			EmailManager.clearAllLocks();
			CaseAPI.upsertCaseComment(contactContext, nonDraftAPIComment);
			EmailManager.lockExternally();

			List<Database.UpsertResult> srList = Database.upsert(new List<Case_Comment__c> {comment}, false);
			for (Database.UpsertResult sr : srList) {
				if (!sr.isSuccess()) {
					List<String> errorMessageList = new List<String>();
					for (Database.Error err : sr.getErrors()) {
						if (err.getMessage() == CaseComment_Trigger.CANNOT_REVERT_COMMENT_BACK_TO_DRAFT_STATUS_MSG) {
							throw new GenericUtils.InvalidException(CaseComment_Trigger.CANNOT_REVERT_COMMENT_BACK_TO_DRAFT_STATUS_MSG);
						} else {
							errorMessageList.add(err.getMessage());
						}
					}
					throw new GenericUtils.DatabaseException(String.join(errorMessageList, ';'));
				}
			}

			if (!CaseCommentUtils.isDraft(comment)) {
				EmailManager.clearAllLocks();
				EmailManager.CaseParameter emailParam = new EmailManager.CaseParameter();

				if (CaseCommentUtils.isPublic(comment) && oldCaseStatus != newCase.Status) {
					emailParam.caseIds.add(newCase.Id);
					emailParam.statusChangeIds.add(newCase.Id);
				} else {
					EmailManager.CaseCommentParameter commentParam = new EmailManager.CaseCommentParameter();
					commentParam.commentIds.add(comment.id);

					emailParam = commentParam;
				}

				EmailManager.EmailResult emailResult = EmailManager.sendEmails(emailParam);
				emailResult.logReturnReason();
			}

			result = new APIUtils.APIComment(CaseUtils.getCommentById(comment.Id));
			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (GenericUtils.UnknownException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (GenericUtils.InvalidPermissionsException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_FORBIDDEN;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			result.returnCode = APIUtils.STATUS_ISE;
			result.message = e.getMessage();
		} finally {
			logs.flush();
		}

		return result;
	}

	static testMethod void upsertCaseComment_tryToPushADraftAfterMovedToNonDraft_invalid() {
		final String DRAFT_COMMENT_BODY = 'Draft Comment Body';
		User strataUser = TestUtils.getStrataUser();
		User caseOwner = TestUtils.createTseUser(TestUtils.getEmailAddress('redhat.com'));
		caseOwner.Email = caseOwner.SSO_Username__c;
		update caseOwner;

		String ssoName = TestUtils.getEmailAddress('example.com');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact.Email = ssoName;
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase.OwnerId = caseOwner.Id;
		testCase.Case_Owner__c = caseOwner.Id;
		testCase.ContactId = testContact.Id;
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Case_Comment__c testComment;
		System.runAs(strataUser) {
			testComment = TestUtils.getPublicComment(testCase);
			testComment = TestUtils.makeCommentDraft(testComment);
			testComment.Created_By_Contact__c = testContact.Id;
			insert testComment;
		}

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.APIComment apiComment = new APIUtils.APIComment(testComment);
		apiComment.text = DRAFT_COMMENT_BODY;
		apiComment.caseNumber = testCase.CaseNumber;

		Datetime startDate = Datetime.now();
		TestUtils.clearWorkflowEmails(startDate);

		List<WorkflowEmail__c> workflowEmails = TestUtils.getWorkflowEmailsSince(startDate);
		System.assertEquals(0, workflowEmails.size(), 'Emails sent when we were not expecting to send emails');

		APIUtils.APIComment result;
		System.runAs(strataUser) {
			Test.startTest();
			result = upsertCaseComment(contactContext, apiComment);
			Test.stopTest();
		}

		System.assertEquals(APIUtils.STATUS_BAD, result.returnCode, 'Did not get the right return code back [' + result.message + ']');

		workflowEmails = TestUtils.getWorkflowEmailsSince(startDate);
		System.assertEquals(2, workflowEmails.size(), 'Did not get the expected number of emails back');

		WorkflowEmail__c internalWorkflowEmail, externalWorkflowEmail;
		for (WorkflowEmail__c workflowEmail : workflowEmails) {
			if (workflowEmail.To_0__c == testContact.Email) {
				externalWorkflowEmail = workflowEmail;
			} else if (workflowEmail.To_0__c == caseOwner.Email) {
				internalWorkflowEmail = workflowEmail;
			} else {
				System.assert(false, 'received a weirdly addressed email: ' + workflowEmail.To_0__c);
			}
		}

		System.assert(internalWorkflowEmail.Body__c.contains('Most recent comment:'), 'should have "Most recent comment" in internal text');
		System.assert(externalWorkflowEmail.Body__c.contains('Most recent comment:'), 'should have "Most recent comment" in external text');

		System.assert(internalWorkflowEmail.Body__c.contains(CaseAPI_upsertCaseComment_Test.NON_DRAFT_COMMENT_BODY), 'should have non-draft comment body in internal text');
		System.assert(externalWorkflowEmail.Body__c.contains(CaseAPI_upsertCaseComment_Test.NON_DRAFT_COMMENT_BODY), 'should have non-draft comment body in external text');

		Case_Comment__c newComment = TestUtils.fetchComment(testComment);

		System.assertEquals(testCase.Id, newComment.Case__c, 'Did not get assigned to the right case');
		System.assertEquals(CaseAPI_upsertCaseComment_Test.NON_DRAFT_COMMENT_BODY, newComment.Comment_Body__c, 'Did not get the right body back');
		System.assert(newComment.Is_Public__c, 'Did not get the right public status back');
		System.assert(!newComment.Is_Draft__c, 'Should not be draft because it was marked as non-draft');
		System.assertEquals(testContact.Id, newComment.Created_By_Contact__c, 'Did not get the right created by');
	}

