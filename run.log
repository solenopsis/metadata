		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.SEVERITY_ONE, testCase.Severity__c, 'The severity did not get updated');

		testNEP = TestUtils.fetchNepForCase(testCase);
		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.TargetDate__c, 'target date should no longer be nep date');
		System.assertEquals(null, testNEP, 'The case should not have a NEP');
	}

