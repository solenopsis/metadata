	static testMethod void listCaseComments_private_shared_valid() {
		String commentBody1 = '_unittest_comment_: 001';
		String commentBody2 = '_unittest_comment_: 002';
		String commentBody3 = '_unittest_comment_: 003';
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		External_Tracker__c testTracker = TestUtils.getExternalTracker(testCase);
		testTracker.System__c = TestUtils.getUniqueString('system_name');
		testTracker.System_Instance__c = TestUtils.getUniqueString('system_instance');
		testTracker.Ticket_Reference__c = TestUtils.getUniqueString('reference');
		insert testTracker;

		testTracker = TestUtils.fetchExternalTracker(testTracker);

		String partnerPrivateMap = '{"' + testTracker.Id + '":true}';

		List<Case_Comment__c> testComments = new List<Case_Comment__c>();
		testComments.add(TestUtils.getPublicComment(testCase, commentBody1));
		testComments.add(TestUtils.getPublicComment(testCase, commentBody3));

		Case_Comment__c testComment = TestUtils.getPrivateComment(testCase, commentBody2);
		testComment.External_Tracker_To_Partner_Private_Map__c = partnerPrivateMap;
		testComments.add(testComment);

		insert testComments;

		Map<String, Case_Comment__c> expectedResults = new Map<String, Case_Comment__c>();
		Map<String, Case_Comment__c> privateResults = new Map<String, Case_Comment__c>();

		for (Case_Comment__c comment : testComments) {
			if (comment.Comment_Body__c == commentBody1) {
				expectedResults.put(commentBody1, comment);
			} else if (comment.Comment_Body__c == commentBody2) {
				expectedResults.put(commentBody2, comment);
				privateResults.put(commentBody2, comment);
			} else if (comment.Comment_Body__c == commentBody3) {
				expectedResults.put(commentBody3, comment);
			}
		}

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APIComments results = CaseAPI.listCaseComments(contactContext, caseContext);

		Test.stopTest();

		List<String> etList = new List<String> {testTracker.Name};

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(3, results.comments.size(), 'Did not get the right number of comments back');

		for (APIUtils.APIComment result : results.comments) {
			if (!expectedResults.containsKey(result.text)) {
				System.assert(false, 'Got a comment back we did not expect [' + result.text + ']');
			}

			Case_Comment__c expected = expectedResults.remove(result.text);
			System.assertEquals(expected.Id, result.Id, 'Did not get the right id back');
			System.assertEquals(expected.Comment_Body__c, result.text, 'Did not get the right body back');
			if (privateResults.containsKey(result.text)) {
				System.assert(!result.isPublic, 'Should not be public');
				System.assert(!result.isDraft, 'Should not be draft');
				System.assertEquals(etList, result.sharePrivateWithExternalTrackers, 'Private partner list is [' + result.sharePrivateWithExternalTrackers + '] which is not correct');
			} else {
				System.assert(result.isPublic, 'Should be public');
				System.assert(GenericUtils.isEmptyList(result.sharePrivateWithExternalTrackers), 'Private partner map is [' + result.sharePrivateWithExternalTrackers + '], should be empty');
			}
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the expected results back [' + expectedResults.keySet() + ']');
	}

