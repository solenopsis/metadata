		System.assertEquals(testCase.Status, result.cases.get(0).status, 'Did not get the right status back');
		System.assertEquals(testCase.Subject, result.cases.get(0).summary, 'Did not get the right subject back');
		System.assertEquals(testCase.SuppliedEmail, result.cases.get(0).suppliedEmail, 'Did not get the right supplied email back');
		System.assertEquals(testCase.SuppliedName, result.cases.get(0).suppliedName, 'Did not get the right supplied name back');
		System.assertEquals(testCase.SuppliedPhone, result.cases.get(0).suppliedPhone, 'Did not get the right supplied phone back');
		System.assertEquals(testCase.Type, result.cases.get(0).caseType, 'Did not get the right case type back');
		System.assertEquals(testCase.UserAgent__c, result.cases.get(0).userAgent, 'Did not get the right user agent back');
		System.assert(result.cases.get(0).isStrategicAccount, 'isStrategicAccount expected to be true');
	}

