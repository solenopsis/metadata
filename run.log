				System.assertEquals(link2.resourceViewURI, crr.Resource_View_URI__c, 'Did not get the right url for the second link');
				System.assertEquals(CaseResourceRelationshipUtils.TYPE_LINK, crr.Type__c, 'relationship type should be "Link"');
				System.assertEquals(CaseResourceRelationshipUtils.LINKING_MECHANISM_STRATA, crr.linking_Mechanism__c, 'linking mechanism should be Strata');
				System.assert(TestUtils.isWithinThreshold(30 * 1000, crr.Linked_At__c.getTime(), Datetime.now().getTime()), 'linked_date__c should be within threshold');
				System.assertEquals(null, crr.Pinning_Mechanism__c, 'pinning mechanism should be null');
				System.assertEquals(null, crr.Pinned_At__c, 'pinned date should be null');
			} else {
				System.assert(false, 'Got a link we were not expecting ['+crr.Resource_View_URI__c+']');
			}
		}

		System.assert(gotLink1, 'Did not get the first link');
		System.assert(gotLink2, 'Did not get the second link');
	}

