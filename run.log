/**
* Test class for CaseAPI getSBRs method
*
* @author Patrick Connelly (pconnell@redhat.com)
*/

@isTest
private class CaseAPI_getSBRs_Test {
	//////////////////////////////////////////////////////////////////////////
	//                             getSBRs                                  //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void getSBRs_valid() {
		Set<String> expectedResults = new Set<String>(GenericUtils.getPicklistLabels(Case.SBR_Group__c.getDescribe()));

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.getSBRs();

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code ['+results.message+']');
		System.assertEquals(expectedResults.size(), results.values.size(), 'Did not get the right number of languages back');

		for (String lang : results.values) {
			System.assert(expectedResults.contains(lang), 'Got a language we did not expect ['+lang+']');
			expectedResults.remove(lang);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the languages we expected ['+expectedResults+']');
	}

	static testMethod void getSBRs_ise_invalid() {
		APIUtils.THROW_EXCEPTION = true;

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.getSBRs();

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_ISE, results.returnCode, 'Did not get the right return code ['+results.message+']');
		System.assertEquals(GenericUtils.MSG_ISE, results.message, 'Got the right return code but the wrong message');
	}
}
