	WebService static APIUtils.APICase getMostRecentlyUpdatedCase(APIUtils.ContactContext callingContext, APIUtils.ContactContext contactContext) {
		final List<Object> paramList = new List<Object> {callingContext, contactContext};
		final String methodName = 'getMostRecentlyUpdatedCase';
		APIUtils.APICase result = new APIUtils.APICase();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(callingContext);

			Contact callingContact = callingContext.getContact();

			Contact contact = null;

			try {
				APIUtils.ensureContactContext(contactContext);
				contact = contactContext.getContact();
			} catch (APIUtils.BadContactException e) {
				GenericUtils.reportException('ContactContext not set.  Defaulting to calling contact [' + callingContext + ']', e, GenericUtils.DEBUG);

				contactContext = callingContext;
				contact = callingContact;
			}

			APIUtils.ensureAccountSameness(callingContact, contact, callingContext.isInternal);

			List<Case> cases = CaseUtils.getCasesForAccount(contact.AccountId, true);
			Case resultCase = null;

			List<Group_Member__c> membership = AccountUtils.getMembershipForContact(contact);

			for (Case kase : cases) {
				try {
					APIUtils.ensureEndpointAccess(callingContext, kase);
					APIUtils.ensureCaseAccess(kase, contact, contactContext.isInternal, membership);
					resultCase = kase;
					break;
				} catch (APIUtils.InvalidPermissionsException e) {
					GenericUtils.reportException('Contact does not have access to case [' + kase.CaseNumber + '] continuing', e, GenericUtils.DEBUG);
				}
			}

			if (resultCase == null) {
				throw new GenericUtils.UnknownException(GenericUtils.MSG_NO_CASES_FOUND);
			}

			result = new APIUtils.APICase(resultCase, callingContext.isInternal);
			result.setCallingContact(contact, callingContext.isInternal);
			result.enrichCaseData();
			result.returnCode = APIUtils.STATUS_OK;
