	static testMethod void listCases_filter_caseNumber_multi_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase1 = TestUtils.getCase(testAccount);
		insert testCase1;

		testCase1 = TestUtils.fetchCase(testCase1);

		Case testCase2 = TestUtils.getCase(testAccount);
		insert testCase2;

		testCase2 = TestUtils.fetchCase(testCase2);

		Case testCase3 = TestUtils.getCase(testAccount);
		insert testCase3;

		testCase3 = TestUtils.fetchCase(testCase3);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();
		cFilter.caseNumbers = new List<String>{testCase1.CaseNumber, testCase3.CaseNumber};

		Test.startTest();

		APIUtils.APICases results = CaseAPI.listCases(cContext, aContext, cFilter);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right status back ['+results.message+']');
		System.assertEquals(cFilter.caseNumbers.size(), results.cases.size(), 'Did not get the right number of cases back');

		Map<Id, Case> expectedResults = new Map<Id, Case>{testCase1.Id => testCase1, testCase3.Id => testCase3};

		for (APIUtils.APICase result : results.cases) {
			if (!expectedResults.containsKey(result.Id)) {
				System.assert(false, 'Got a case we did not expect [' + result.summary + ']');
			} else {
				System.assertEquals(expectedResults.get(result.Id).subject, result.summary, 'Did not get the right case back');
				expectedResults.remove(result.Id);
			}
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the expected cases [' + expectedResults.keySet() + ']');
	}

