/**
* Test class for CaseAPI listSeverity
*
* @author Patrick Connelly (pconnell@redhat.com)
*/

@isTest
private class CaseAPI_listSeverity_Test {
	//////////////////////////////////////////////////////////////////////////
	//                            listSeverity                              //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void listSeverity_valid() {
		Set<String> expectedResults = new Set<String>(GenericUtils.getPicklistLabels(Case.Severity__c.getDescribe()));
		Set<String> knownResults = GenericUtils.KNOWN_SEVERITY;

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.listSeverity(cContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(expectedResults.size(), results.values.size(), 'Did not get the right number of severities back');

		for (String severity : results.values) {
			System.assert(expectedResults.contains(severity), 'Got a severity we did not expect [' + severity + ']');
			expectedResults.remove(severity);
			knownResults.remove(severity);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the severities we expected [' + expectedResults + ']');
		System.assert(knownResults.isEmpty(), 'Did not get all the known severities we expected [' + knownResults + ']');
	}

	static testMethod void listSeverity_contact_bad_invalid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		APIUtils.ContactContext cContext = null;

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.listSeverity(cContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_BAD, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(GenericUtils.MSG_NULL_SSONAME, results.message, 'Got the right return code but the wrong message');
	}

	static testMethod void listSeverity_contact_unknown_invalid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);

