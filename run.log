		kase = CaseAPI.updateCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code [' + kase.message + ']');

		Case result = TestUtils.fetchCase(new Case(Id = kase.Id));

		System.assertEquals(testAccount.Id, result.AccountId, 'Did not get the right account back');
		System.assertEquals(testEntitlement1.Id, result.EntitlementId, 'Did not get the right entitlement back');
		System.assertEquals(serviceLevel, result.Entitlement.Service_Level_Label__c, 'Did not get back expected service level');
		System.assertEquals(serviceLevel, result.Initial_Service_Level__c, 'Did not get back expected Initial Service Level');
	}

