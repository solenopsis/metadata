	static testMethod void addCaseContacts_orgAdmin_valid() {
		String ssoName1 = TestUtils.getUniqueString('_unittest_sso_: 001');
		String ssoName2 = TestUtils.getUniqueString('_unittest_sso_: 002');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testContact1 = TestUtils.getContactWithSSOName(testAccount, ssoName1);
		testContact1 = TestUtils.makeContactOrgAdmin(testContact1);
		insert testContact1;

		Contact testContact2 = TestUtils.getContactWithSSOName(testAccount, ssoName2);
		insert testContact2;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact1);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		List<APIUtils.APIContact> contactList = new List<APIUtils.APIContact>();
		contactList.add(new APIUtils.APIContact(testContact1));
		contactList.add(new APIUtils.APIContact(testContact2));

		Test.startTest();

		APIUtils.APIResult result = CaseAPI.addCaseContacts(contactContext, caseContext, contactList);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');

		Set<Id> expectedResults = new Set<Id>{
			testContact1.Id,
			testContact2.Id
		};

		List<User_Case_Contact__c> caseContactList = TestUtils.fetchCustomerCaseContacts(testCase);
		System.assertEquals(expectedResults.size(), caseContactList.size(), 'Did not get the number of contacts we expected');

		for (User_Case_Contact__c ucc: caseContactList) {
			System.assert(expectedResults.contains(ucc.Contact_Id__c), 'Got a contact we did not expect');
			expectedResults.remove(ucc.Contact_Id__c);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the results we expected');
	}

