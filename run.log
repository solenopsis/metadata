	static testMethod void listCasesforContactForJustCreatedCaseWithStartAndEnddateTest() {
		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		String ssoName = TestUtils.getUniqueString('_unittest_contact: sso');
		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		insert testEntitlement;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.APICase kase = TestUtils.getAPICase(testProduct, testVersion);

		kase = CaseAPI.createCase(cContext, kase);

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code ['+kase.message+']');

		Case testCase = TestUtils.fetchCase(new Case(Id = kase.Id));

		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();
		cFilter.startDate = kase.lastModifiedDate;
		cFilter.endDate = kase.lastModifiedDate.addSeconds(1);
		Test.startTest();

		APIUtils.APICases result =  CaseAPI.listCases(cContext, aContext, cFilter);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.AssertEquals(1, result.cases.size(),'should get one case back');
		System.AssertEquals(testCase.caseNumber, result.cases.get(0).caseNumber, 'wrong case in result');
	}

