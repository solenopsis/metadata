	static testMethod void updateCase_internal_valid() {
		String ssoName = TestUtils.getEmailAddress('redhat.com');

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		Account testAccount1 = TestUtils.getAccount();
		insert testAccount1;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount1);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Account testAccount2 = TestUtils.getAccount(TestUtils.getUniqueString('133713371337'));
		insert testAccount2;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount2, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getFullCase(testAccount1);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		User testUser = TestUtils.CreateTSEUser(ssoName);

		String resolution = 'Unresolved: Abandoned';
		String actionPlan = 'Test Action Plan';

		APIUtils.ContactContext context = new APIUtils.ContactContext(ssoName);
		APIUtils.APICase kase = new APIUtils.APICase();
		kase.caseNumber = testCase.CaseNumber;
		kase.description = '_unittest_description: 002';
		kase.resolution = resolution;
		kase.actionPlan = actionPlan;

		Test.startTest();

		APIUtils.APICase result;
		Datetime NOW = APIUtils.NOW;

		System.runAs(testUser) {
			result = CaseAPI.updateCase(context, kase);
		}

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code [' + result.message + ']');

		Case fetchedCase = TestUtils.fetchCase(testCase);

		System.assertEquals(kase.description, fetchedCase.Description, 'Description does not match');
		System.assertEquals(resolution, fetchedCase.Resolution1__c, 'Resolution does not match');
		System.assertEquals(actionPlan, fetchedCase.Action_Plan__c, 'Action Plan does not match');
		System.assertEquals(NOW, fetchedCase.ActionPlan_Last_Updated__c, 'Action Plan last updated time incorrect');
		System.assertEquals(testUser.Id, fetchedCase.ActionPlan_Last_Updated_By_User__c, 'Action plan last updated by user incorrect');
	}

