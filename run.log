/**
* Test class for CaseAPI KCS functionality
*
* @author Patrick Connelly (pconnell@redhat.com)
*/

@isTest
private class CaseAPI_KCS_Test {
	@TestSetup
	static void setUp() {
		TestUtils.setupProductAndVersion();
	}

	//////////////////////////////////////////////////////////////////////////
	//                           KCS Link/Pin                               //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void createCase_createLink_single_valid_viaCRRManager_createsKCSLink() {
		TestUtils.parallelSetupKCSSettings();

		String solutionId = TestUtils.getUniqueString('12345');
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Article__c article = TestUtils.getDefaultArticle();
		article.Title__c = 'blah';
		article.Name = solutionId;
		insert article;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		insert testEntitlement;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.APICase kase = TestUtils.getAPICase(testProduct, testVersion);
		APIUtils.APICaseResourceLink link = new APIUtils.APICaseResourceLink();
		link.title = article.Title__c;
		link.resourceType = CaseResourceRelationshipUtils.RESOURCE_TYPE_SOLUTION;
		link.resourceId = solutionId;
		link.resourceURI = GenericUtils.solution_resource_uri(link.resourceId);
		link.resourceViewURI = GenericUtils.solution_resource_view_uri(link.resourceId);
		link.linked = true;

		kase.caseResourceLinks = new APIUtils.APICaseResourceLinks(new List<APIUtils.APICaseResourceLink>{link});

		Test.startTest();

		kase = CaseAPI.createCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code ['+kase.message+']');

		Case result = TestUtils.fetchCase(kase.caseNumber);
		List<KCS_Link__c> kcsLinks = TestUtils.fetchKCSLinksForCase(result);

		System.assertEquals(1, kcsLinks.size(), 'Did not get the right number of links back');

		System.assertEquals(article.Id, kcsLinks.get(0).Article__c, 'Did not get the right article back');
		System.assertEquals(article.KBase_URL__c, kcsLinks.get(0).KBase_URL__c, 'Did not get the right link back');

		System.assertEquals(KCS_Link_Utils.RELATIONSHIPTYPE_PIN, kcsLinks.get(0).relationshipType__c, 'Did not get the correct relationship Type');
		System.assertEquals(null, kcsLinks.get(0).linkingMechanism__c, 'Did not get the correct Linking Mechanism');
		System.assertEquals(KCS_Link_Utils.PINNING_MECHANISM_STRATA, kcsLinks.get(0).pinningMechanism__c, 'Did not get the correct Pinning Mechanism');

		System.assertEquals(article.KBase_URL__c, kcsLinks.get(0).KBase_URL__c, 'Did not get the right link back');
		System.assertEquals(article.Id, kcsLinks.get(0).Article__c, 'Did not get the right article back');
		System.assertEquals(KCS_Link_Utils.ORIGIN_CALAVERAS_SUGGESTION, kcsLinks.get(0).origin__c, 'Did not get the correct Origin');
	}

	static testMethod void createCase_createLink_single_valid_viaCRRManager_createsCRR() {
		TestUtils.parallelSetupKCSSettings();

		String solutionId = TestUtils.getUniqueString('12345');
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Article__c article = TestUtils.getDefaultArticle();
