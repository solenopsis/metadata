	static testMethod void updateCase_suggestedLink_multi_valid_with_User_viaCRRManager_createsKCSLink() {
		TestUtils.parallelSetupKCSSettings();

		String ssoName = TestUtils.getEmailAddress('redhat.com');

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		CaseFolder__c testGroup = TestUtils.getGroup(testAccount);
		insert testGroup;

		testGroup = TestUtils.fetchGroup(testGroup);

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		User testUser = TestUtils.createTseUser(ssoName);

		Case testCase = TestUtils.getFullCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext context = new APIUtils.ContactContext(ssoName);
		APIUtils.APICase kase = new APIUtils.APICase();
		kase.caseNumber = testCase.CaseNumber;

		APIUtils.APICaseResourceLink link1 = new APIUtils.APICaseResourceLink(GenericUtils.solution_resource_view_uri('10000T'));
		APIUtils.APICaseResourceLink link2 = new APIUtils.APICaseResourceLink(GenericUtils.solution_resource_view_uri('10001T'));

		List<APIUtils.APICaseResourceLink> links = new List<APIUtils.APICaseResourceLink>{link1, link2};
		Integer i = 0;
		for (APIUtils.APICaseResourceLink link : links) {
			link.resourceId = '1000' + i + 'T';
			link.linked = true;
			link.title = 'Title: ' + i;
			link.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
			link.origin = KCS_Link_Utils.ORIGIN_SUGGESTION;
			i += 1;
		}
		kase.caseResourceLinks = new APIUtils.APICaseResourceLinks(links);

		Test.startTest();

		kase = CaseAPI.updateCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code ['+kase.message+']');

		List<KCS_Link__c> results = TestUtils.fetchKCSLinksForCase(testCase);

		System.assertEquals(links.size(), results.size(), 'Did not get the right number of links back');

		Boolean gotLink1 = false;
		Boolean gotLink2 = false;

		for (KCS_Link__c result : results) {
			if (result.Solution_Id__c == '10000T') {
				gotLink1 = true;
				System.assertEquals(GenericUtils.solution_resource_view_uri('10000T'), result.KBase_URL__c, 'Did not get the right url for the first link');
				System.assertEquals('Title: 0', result.Title__c, 'Did not get the right title for the first link');
			} else if (result.Solution_Id__c == '10001T') {
				System.assertEquals(GenericUtils.solution_resource_view_uri('10001T'), result.KBase_URL__c, 'Did not get the right url for the second link');
				System.assertEquals('Title: 1', result.Title__c, 'Did not get the right title for the second link');
				gotLink2 = true;
			} else {
				System.assert(false, 'Got a link we were not expecting ['+result.KBase_URL__c+']');
			}
			System.assertEquals(KCS_Link_Utils.RELATIONSHIPTYPE_LINK, result.relationshipType__c, 'Did not get the correct relationship Type');
			System.assertEquals(KCS_Link_Utils.LINKING_MECHANISM_STRATA, result.linkingMechanism__c, 'Linking Mechanism should be Strata');
			System.assertEquals(null, result.pinningMechanism__c, 'Pinning Mechanism should be null');
			System.assertEquals(KCS_Link_Utils.ORIGIN_CALAVERAS_SUGGESTION, result.origin__c, 'Did not get the correct Origin');
		}

		System.assert(gotLink1, 'Did not get the first link');
		System.assert(gotLink2, 'Did not get the second link');
	}

