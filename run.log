*
* @author Patrick Connelly (pconnell@redhat.com)
*/

@isTest
private class CaseAPI_addCaseTags_Test {
	@TestSetup
	static void setUp() {
		TestUtils.setupProductAndVersion();
	}

	//////////////////////////////////////////////////////////////////////////
	//                           addCaseTags                                //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void addCaseTags_single_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Object_Tag__c testTag = TestUtils.getObjectTagForCase();
		insert testTag;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		List<String> tags = new List<String> {
			testTag.Tag__c
		};

		Test.startTest();

		APIUtils.APICase result = CaseAPI.addCaseTags(contactContext, caseContext, tags);

		Test.stopTest();

		Set<String> expectedResults = new Set<String>(Tags);

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code ['+result.message+']');
		System.assertEquals(expectedResults.size(), result.tags.size(), 'Did not get the right number of Tags back');

		for (String tag : result.tags) {
			if (!expectedResults.contains(tag)) {
				System.assert(false, 'Got an tag we did not expect ['+tag+']');
			}

			expectedResults.remove(tag);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the Tags back that we expected ['+expectedResults+']');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.joinMultiselectList(Tags), testCase.Tags__c, 'Did not get the right information stored on the case');
	}

