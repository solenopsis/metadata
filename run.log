	static testMethod void removeCaseTags_private_internal_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase = TestUtils.makePrivate(testCase);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Object_Tag__c testTag1 = TestUtils.getObjectTagForCase();
		Object_Tag__c testTag2 = TestUtils.getObjectTagForCase();

		insert new List<Object_Tag__c> {
			testTag1,
			testTag2
		};

		Case_Tag_Link__c testCaseTag1 = TestUtils.getCaseObjectTag(testCase, testTag1);
		Case_Tag_Link__c testCaseTag2 = TestUtils.getCaseObjectTag(testCase, testTag2);

		insert new List<Case_Tag_Link__c>{
			testCaseTag1,
			testCaseTag2
		};

		List<String> toRemoveTags = new List<String>{
			testTag2.Tag__c
		};

		APIUtils.contactContext contactContext = new APIUtils.contactContext(testContact);
		APIUtils.caseContext caseContext = new APIUtils.caseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.removeCaseTags(contactContext, caseContext, toRemoveTags);

		Test.stopTest();

		Set<String> expectedResults = new Set<String> {
			testTag1.Tag__c
		};

		System.assertEquals(APIUTils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.assertEquals(expectedResults.size(), result.tags.size(), 'Did not get the right number of Tags back');

		for (String tag : result.tags) {
			if (!expectedResults.contains(tag)) {
				System.assert(false, 'Got an tag we did not expect ['+tag+']');
			}

			expectedResults.remove(tag);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the results we expected ['+expectedResults+']');

		expectedResults = new Set<String> {
			testTag1.Tag__c
		};

		testCase = TestUtils.fetchCase(testCase);

		for (String tag : GenericUtils.splitMultiselectList(testCase.Tags__c)) {
			if (!expectedResults.contains(tag)) {
				System.assert(false, 'Got an tag we did not expect ['+tag+']');
			}

			expectedResults.remove(tag);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get back all the results we expected ['+expectedResults+']');
	}

