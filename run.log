		expectedMap.remove('LINKING_MECHANISM');
		expectedMap.remove('SEARCH_TERM');
		expectedMap.remove('SORT_METHOD');
		expectedMap.remove('SORT_ORDER_INDEX');

		TestUtils.crrEquivalence(expectedMap, crr);
	}

