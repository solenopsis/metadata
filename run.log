		testCase = TestUtils.fetchCase(testCase);

		List<Article__c> articleList = new List<Article__c>();
		articleList.add(TestUtils.getArticle('1 Article'));
		articleList.add(TestUtils.getArticle('2 Article'));
		articleList.add(TestUtils.getArticle('3 Article'));
		articleList.add(TestUtils.getArticle('4 Article'));
		articleList.add(TestUtils.getArticle('5 Article'));
		articleList.add(TestUtils.getArticle('6 Article'));
		articleList.add(TestUtils.getArticle('7 Article'));
		articleList.add(TestUtils.getArticle('8 Article'));

		insert articleList;

		// --------
		// 1 higher bucket, older suggestion
		// 1 lower bucket, older suggestion
		List<KCS_Link__c> suggestionList = new List<KCS_Link__c>();
		suggestionList.add(TestUtils.getSuggestedKCSLink(testCase.Id, articleList.get(0).Id));
		suggestionList.add(TestUtils.getSuggestedKCSLink(testCase.Id, articleList.get(1).Id));

		String sfdcUserNameAndSSOName = TestUtils.getEmailAddress('redhat.com');
		User testUser = TestUtils.createTseUser(sfdcUserNameAndSSOName);

		System.runAs(testUser) {
			suggestionList.get(0).Display__c = true;
			suggestionList.get(0).Bucket__c = '5.0';

			suggestionList.get(1).Display__c = true;
			suggestionList.get(1).Bucket__c = '2.0';
		}

		insert suggestionList; // separate insertion from below because LastModifiedDate Matters

		// --------
		// 1 higher bucket, newer suggestion
		// 1 lower bucket, newer suggestion
		suggestionList = new List<KCS_Link__c>();
		suggestionList.add(TestUtils.getSuggestedKCSLink(testCase.Id, articleList.get(2).Id));
		suggestionList.add(TestUtils.getSuggestedKCSLink(testCase.Id, articleList.get(3).Id));

		System.runAs(testUser) {
			suggestionList.get(0).Display__c = true;
			suggestionList.get(0).Bucket__c = '5.0';

			suggestionList.get(1).Display__c = true;
			suggestionList.get(1).Bucket__c = '2.0';
		}

		insert suggestionList;

		// --------
		// 2 links associate
		List<KCS_Link__c> linkedByAssociateList = new List<KCS_Link__c>();
		linkedByAssociateList.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(4).Id));
		linkedByAssociateList.add(TestUtils.getLinkedKCSLink(testCase.Id, articleList.get(5).Id));

		System.runAs(testUser) {
			for (KCS_Link__c kcsLink : linkedByAssociateList) {
				kcsLink.Relationship_Established_By__c = UserInfo.getUserId();
			}

			// linkedByAssociateList.get(0).Relationship_Established_Date__c = Datetime.now().addDays(5);
			// linkedByAssociateList.get(1).Relationship_Established_Date__c = Datetime.now().addDays(-5);
		}

		insert linkedByAssociateList;

		Map<String,String> inputMap = new Map<String,String>{
			KCS_Link_Utils.ARTICLE_OWNER_SSO_NAME_FIELD     => sfdcUserNameAndSSOName,
			KCS_Link_Utils.LINKED_BY_SSO_NAME_FIELD         => ssoName,
			KCS_Link_Utils.CASE_ID_FIELD                    => testCase.id,
			KCS_Link_Utils.COPIED_FROM_SFDC_FIELD           => 'false',
			KCS_Link_Utils.ORIGIN_FIELD                     => KCS_Link_Utils.ORIGIN_SUGGESTION,
			KCS_Link_Utils.LINKING_MECHANISM_FIELD          => KCS_Link_Utils.LINKING_MECHANISM_STRATA
		};

		// --------
		// 2 links by non associate
		User strataUser = TestUtils.getStrataUser();

		System.runAs(strataUser) {
			inputMap.put(KCS_Link_Utils.SOLUTION_ID_FIELD, articleList.get(6).Name);
			inputMap.put(KCS_Link_Utils.TITLE_FIELD, articleList.get(6).Title__c);
			inputMap.put(KCS_Link_Utils.KCS_STATE_FIELD, articleList.get(6).KCS_State__c);
			inputMap.put(KCS_Link_Utils.KBASE_URL_FIELD, articleList.get(6).KBase_URL__c);
			List<KCS_Link__c> linkedByContactList = new List<KCS_Link__c>{ KCS_Link_Utils.link(inputMap) };

			inputMap.put(KCS_Link_Utils.SOLUTION_ID_FIELD, articleList.get(7).Name);
			inputMap.put(KCS_Link_Utils.TITLE_FIELD, articleList.get(7).Title__c);
			inputMap.put(KCS_Link_Utils.KCS_STATE_FIELD, articleList.get(7).KCS_State__c);
			inputMap.put(KCS_Link_Utils.KBASE_URL_FIELD, articleList.get(7).KBase_URL__c);
			linkedByContactList.add(KCS_Link_Utils.link(inputMap));

			insert linkedByContactList;
		}

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(context, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');
		System.Debug('RESULTS: ' + result.caseresourcelinks);
		System.assertEquals(8, result.caseresourcelinks.size(), 'Did not get the right number of caseresourcelinks back: 2');

		System.assertEquals(null, result.caseresourcelinks.get(0).linkedBy, 'linkedBy is null because one link was done by Customer');
		System.assertEquals(ssoName, result.caseresourcelinks.get(0).pinnedBy, 'pinnedBy is set to customer SSO Name');
		System.assert(result.caseresourcelinks.get(0).resourceId.startsWith('7 Article') || result.caseresourcelinks.get(0).resourceId.startsWith('8 Article'), 'First link is one pinned by customer');

		System.assertEquals(null, result.caseresourcelinks.get(1).linkedBy, 'linkedBy is null because one link was done by Customer');
		System.assertEquals(ssoName, result.caseresourcelinks.get(1).pinnedBy, 'pinnedBy is set to customer SSO Name');
		System.assert(result.caseresourcelinks.get(1).resourceId.startsWith('7 Article') || result.caseresourcelinks.get(1).resourceId.startsWith('8 Article'), 'Second link is one pinned by customer');

		System.assertEquals(sfdcUserNameAndSSOName, result.caseresourcelinks.get(2).linkedBy, 'linkedBy is set because link was done by associate');
		System.assertEquals(null, result.caseresourcelinks.get(2).pinnedBy, 'pinnedBy is set to null for associate link');
		System.assert(result.caseresourcelinks.get(2).resourceId.startsWith('5 Article') || result.caseresourcelinks.get(2).resourceId.startsWith('6 Article'), 'Third link is one pinned by Associate');

		System.assertEquals(sfdcUserNameAndSSOName, result.caseresourcelinks.get(3).linkedBy, 'linkedBy is set because link was done by associate');
		System.assertEquals(null, result.caseresourcelinks.get(3).pinnedBy, 'pinnedBy is set to null for associate link');
		System.assert(result.caseresourcelinks.get(3).resourceId.startsWith('5 Article') || result.caseresourcelinks.get(3).resourceId.startsWith('6 Article'), 'Fourth link is one pinned by Associate');

		System.assertEquals(null, result.caseresourcelinks.get(4).linkedBy, 'linkedBy is set to null for suggestion');
		System.assertEquals(null, result.caseresourcelinks.get(4).pinnedBy, 'pinnedBy is set to null for suggestion');
		System.assert(result.caseresourcelinks.get(4).resourceId.startsWith('3 Article') || result.caseresourcelinks.get(4).resourceId.startsWith('1 Article'), 'Fifth link is suggestion');
		System.assertEquals('5', result.caseresourcelinks.get(4).bucket, 'Fifth link has bucket value of 5');

		System.assertEquals(null, result.caseresourcelinks.get(5).linkedBy, 'linkedBy is set to null for suggestion');
		System.assertEquals(null, result.caseresourcelinks.get(5).pinnedBy, 'pinnedBy is set to null for suggestion');
		System.assert(result.caseresourcelinks.get(5).resourceId.startsWith('3 Article') || result.caseresourcelinks.get(5).resourceId.startsWith('1 Article'), 'Sixth link is suggestion');
		System.assertEquals('5', result.caseresourcelinks.get(4).bucket, 'Sixth link has bucket value of 5');

		System.assertEquals(null, result.caseresourcelinks.get(6).linkedBy, 'linkedBy is set to null for suggestion');
		System.assertEquals(null, result.caseresourcelinks.get(6).pinnedBy, 'pinnedBy is set to null for suggestion');
		System.assert(result.caseresourcelinks.get(6).resourceId.startsWith('2 Article') || result.caseresourcelinks.get(6).resourceId.startsWith('4 Article'), 'Seventh link is suggestion');
		System.assertEquals('2', result.caseresourcelinks.get(6).bucket, 'Seventh link has bucket value of 2');

		System.assertEquals(null, result.caseresourcelinks.get(7).linkedBy, 'linkedBy is set to null for suggestion');
		System.assertEquals(null, result.caseresourcelinks.get(7).pinnedBy, 'pinnedBy is set to null for suggestion');
		System.assert(result.caseresourcelinks.get(7).resourceId.startsWith('2 Article') || result.caseresourcelinks.get(7).resourceId.startsWith('4 Article'), 'Eighth link is suggestion');
		System.assertEquals('2', result.caseresourcelinks.get(7).bucket, 'Eigth link has bucket value of 2');
	}

