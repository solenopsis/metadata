	static testMethod void getCase_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String publicComment = '_unittest_comment_public_: 001';
		String privateComment = '_unittest_comment_private_: 001';
		String customerNote = '_unittest_note_: 001';
		DateTime firstReminder = System.now().addDays(-2);
		DateTime secondReminder = System.now().addDays(-1);

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		testCase.customerCaseNotes__c = customerNote;
		testCase.First_Case_Inactivity_Warning_Sent_At__c = firstReminder;
		testCase.Second_Case_Inactivity_Warning_Sent_At__c = secondReminder;
		testCase.LTROC_Closed__c = true;
		testCase.LTROC_Closed_Set__c = true;
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Case_Comment__c testPublicComment = TestUtils.getPublicComment(testCase, publicComment);
		insert testPublicComment;

		Case_Comment__c testPrivateComment = TestUtils.getPrivateComment(testCase, privateComment);
		insert testPrivateComment;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		User_Case_Contact__c testCaseContact = TestUtils.getCustomerCaseContact(testCase, testContact);
		insert testCaseContact;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');
		System.assertEquals(customerNote, result.customerNotes, 'Did not get the same note back');
		System.assert(!result.enhancedSLA, 'The case should not be enhanced');
		System.assertEquals(1, result.comments.size(), 'Did not get the right number of comments back');
		System.assertEquals(publicComment, result.comments.get(0).text, 'Did not get the right comment back');
		System.assertEquals(1, result.contacts.size(), 'Did not get the right number of contacts back');
		System.assertEquals(ssoName, result.contacts.get(0).ssoName, 'Did not get the right contact back');
		System.assertEquals(firstReminder, result.firstCaseInactivityWarningSentAt, 'Did not get expected first reminder');
		System.assertEquals(secondReminder, result.secondCaseInactivityWarningSentAt, 'Did not get expected first reminder');
		System.assert(result.ltrocClosed, 'ltrocClosed should be true');
		System.assert(result.ltrocClosedSet, 'ltrocClosedSet should be true');
	}

	static testMethod void getCase_valid_draft() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String publicComment = '_unittest_comment_public_: 001';
		String draftComment = '_unittest_comment_draft_: 001';

		User testUser = TestUtils.createTSEUser(TestUtils.getEmailAddress('test.redhat.org'));

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case_Comment__c testPublicComment = TestUtils.getPublicComment(testCase, publicComment);
		insert testPublicComment;

		Case_Comment__c testDraftComment = TestUtils.getPublicComment(testCase, draftComment);
		testDraftComment.Is_Draft__c = true;
		testDraftComment.Created_By_Contact__c = testContact.Id;

		System.runAs(testUser) {
			insert testDraftComment;
		}

		User_Case_Contact__c testCaseContact = TestUtils.getCustomerCaseContact(testCase, testContact);
		insert testCaseContact;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');
		System.assertEquals(2, result.comments.size(), 'Did not get the right number of comments back');
		System.assertEquals(1, result.contacts.size(), 'Did not get the right number of contacts back');
		System.assertEquals(ssoName, result.contacts.get(0).ssoName, 'Did not get the right contact back');

		Boolean gotPublic = false;
		Boolean gotDraft = false;

		for (APIUtils.APIComment comment : result.comments) {
			if (publicComment == comment.text) {
				gotPublic = true;
			} else if (draftComment == comment.text && comment.isDraft) {
				gotDraft = true;
			} else {
				System.assert(false, 'Got a comment we did not expect ' + comment);
			}
		}

		System.assert(gotPublic, 'Did not get the public comment back');
		System.assert(gotDraft, 'Did not get the draft comment back');
	}

