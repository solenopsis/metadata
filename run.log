/**
* This class is a webservice that returns information from the Case level
*
* @author Patrick Connelly (pconnell@redhat.com)
* @testClasses CaseAPI_addAttachments_Test CaseAPI_addCaseContacts_Test CaseAPI_addCaseSBRs_Test CaseAPI_addCaseTags_Test CaseAPI_attachmentFilter_Test CaseAPI_commentFilter_Test CaseAPI_createCase_Test CaseAPI_delAttachment_Test CaseAPI_getCaseComment_Test CaseAPI_getCaseLanguages_Test CaseAPI_getCase_Test CaseAPI_getMostRecentlyUpdatedCase_Test CaseAPI_getSBRs_Test CaseAPI_getTags_Test CaseAPI_KCS_Test CaseAPI_listAllCases_Test CaseAPI_listAttachments_Test CaseAPI_listCaseComments_Test CaseAPI_listCaseCommentsWithFilter_Test CaseAPI_listCases_Test CaseAPI_listSeverity_Test CaseAPI_listStatus_Test CaseAPI_listType_Test CaseAPI_removeCaseContacts_Test CaseAPI_removeCaseSBRs_Test CaseAPI_removeCaseTags_Test CaseAPI_search_Test CaseAPI_Test CaseAPI_updateCase_Test CaseAPI_upsertCaseComment_Test CaseAPI_getCase_withBugs_Test CaseAPI_externalTrackerUpdateFilter_Test CaseAPI_listETUWithFilter_Test CaseAPI_addExternalHandlingSystems_Test
*/
global with sharing class CaseAPI {
	public static Set<String> VALID_SORT_ORDERS = new Set<String> {GenericUtils.SORT_ASC, GenericUtils.SORT_DESC};

	/** The filter format */
	@TestVisible private static String FILTER_FORMAT = '{0} {1} {2}';

	/** A generic way to filter case criteria */
	global class CaseFilterCriteria {
		/** The field name to filter */
		WebService String fieldName;

		/** The comparator to use */
		WebService String comparator;

		/** The value to compare it against */
		WebService String value;

		/**
		* Default constructor
		*/
		public CaseFilterCriteria() {}

		/**
		* Constructor with values
		*
		* @param fieldName The field name to filter
		* @param comparator The comparator to use
		* @param value The value to use
		*/
		public CaseFilterCriteria(String fieldName, String comparator, String value) {
			this();
			this.fieldName = fieldName;
			this.comparator = comparator;
			this.value = value;
		}

		/**
		* Determines if criteria is valid
		*
		* @throws GenericUtils.BadException if the filter criteria is not valid
		*/
		@TestVisible
		private void ensureIsValid() {
			if (this.fieldName == null) {
				throw new GenericUtils.BadException(
					String.format(
						GenericUtils.MSG_FILTER_FIELDS_REQUIRED,
						new List<String> {'fieldName'}
					)
				);
			}

			if (this.comparator == null) {
				throw new GenericUtils.BadException(
					String.format(
						GenericUtils.MSG_FILTER_FIELDS_REQUIRED,
						new List<String> {'comparator'}
					)
				);
			}

			if (this.value == null) {
				throw new GenericUtils.BadException(
					String.format(
						GenericUtils.MSG_FILTER_FIELDS_REQUIRED,
						new List<String> {'value'}
					)
				);
			}

			if (
				!APIUtils.case_fieldMap.containsKey(this.fieldName.toLowerCase()) ||
				APIUtils.case_sortBlacklist.contains(this.fieldName.toLowerCase())
			) {
				throw new GenericUtils.BadException(GenericUtils.MSG_INVALID_FIELD);
			}

			if (!GenericUtils.VALID_COMPARATORS.contains(this.comparator)) {
				throw new GenericUtils.BadException(GenericUtils.MSG_INVALID_COMPARATOR);
			}
		}

		/**
		* Gets the criteria for the SOQL
		*
		* @return The criteria
		* @throws GenericUtils.BadException if the filter criteria is not valid
		*/
		public String getCriteria() {
			this.ensureIsValid();

			return String.format(
				FILTER_FORMAT,
				new List<String> {
					this.fieldName,
					this.comparator,
					GenericUtils.quote(this.value)
				}
			);
		}
	}

	/**
	* A class for filtering cases
	*/
	// Test location CaseAPI_Test1.cls
	global class CaseFilter {
		WebService String groupNumber;
		WebService Boolean onlyUngrouped = false;
		webservice Datetime startDate;
		webservice Datetime endDate;
		WebService Boolean includePrivate = false;
		WebService Boolean includeClosed = false;
		WebService Boolean reducedInformation = false;
		WebService String sortField;
		WebService String sortOrder;
		WebService String status;
		WebService String severity;
		WebService String type;
		WebService String ownerSSOName;
		WebService String createdBySSOName;
		WebService String product;
		WebService String keyword;
		WebService List<String> groupNumbers;
		WebService List<String> caseNumbers;
		WebService List<Id> commentIds;
		WebService Integer maxResults = 200;
		WebService Integer offset = 0;
		WebService List<CaseFilterCriteria> criteriaList;

		@TestVisible
		private transient Boolean includeUngrouped = false;

		public Set<Id> caseIds;
		public Set<Id> groupIds;
		public Id accountId;
		public Boolean excludeITARCases = false;

		/**
		* Blank constructor
		*/
		public CaseFilter() {
			criteriaList = new List<CaseFilterCriteria>();
		}

		/**
		* Constructor to set the Casefilter
		*/
		public CaseFilter(String groupNumber, Boolean onlyUngrouped, Datetime startDate, Datetime endDate, Boolean includePrivate, Boolean includeClosed) {
			this.groupNumber = groupNumber;
			this.onlyUngrouped = (onlyUngrouped == null) ? false : onlyUngrouped;
			this.startDate = startDate;
			this.endDate = endDate;
			this.includePrivate = (includePrivate == null) ? false : includePrivate;
			this.includeClosed = (includeClosed == null) ? false : includeClosed;
			this.reducedInformation = (reducedInformation == null) ? false : reducedInformation;
			this.groupNumbers = new List<String>();
			this.caseIds = new Set<Id>();
			this.groupIds = new Set<Id>();
		}

		/**
		* Method to set the booleans to avoid NPE
		*/
		public void setBooleans() {
			this.onlyUngrouped = (this.onlyUngrouped == null) ? false : this.onlyUngrouped;
			this.includeUngrouped = (this.includeUngrouped == null) ? false : this.onlyUngrouped;
			this.includePrivate = (this.includePrivate == null) ? false : this.includePrivate;
			this.includeClosed = (this.includeClosed == null) ? false : this.includeClosed;
			this.reducedInformation = (reducedInformation == null) ? false : reducedInformation;
			this.groupNumbers = (this.groupNumbers == null) ? new List<String>() : this.groupNumbers;
			this.caseNumbers = (this.caseNumbers == null) ? new List<String>() : this.caseNumbers;
			this.commentIds = (this.commentIds == null) ? new List<Id>() : this.commentIds;
			this.caseIds = (this.caseIds == null) ? new Set<Id>() : this.caseIds;
			this.groupIds = (this.groupIds == null) ? new Set<Id>() : this.groupIds;
			this.excludeITARCases = (this.excludeITARCases == null) ? false : this.excludeITARCases;

			if (
				GenericUtils.isNotEmpty(this.status) &&
				this.status == GenericUtils.CLOSED_STATUS
			) {
				this.includeClosed = true;
			}

			List<String> tmpGroupNumbers = new List<String>();

			//This behaves oddly if you pass in a blank group number via soap.
			for (String num : this.groupNumbers) {
				if (GenericUtils.isNotEmpty(num)) {
					tmpGroupNumbers.add(num);
				}
			}

			this.groupNumbers = tmpGroupNumbers;

			if (GenericUtils.isNotEmpty(this.groupNumber)) {
				this.groupNumbers.add(this.groupNumber);
			}
		}

		/**
		* Returns if we care about groups for this criteria
		*
		* @return If we care about groups
		*/
		@TestVisible
		private Boolean hasGroupingCriteria() {
			return !this.groupIds.isEmpty() ||
				this.onlyUngrouped ||
				this.includeUngrouped;
		}

		/**
		* Returns if we care only about cases that are not grouped
		*
		* @return If we only care about cases that are not grouped
		*/
		@TestVisible
		private Boolean onlyInterestedInUngrouped() {
			return this.onlyUngrouped || (
				this.includeUngrouped && this.groupIds.isEmpty()
			);
		}

		/**
		* Gets the criteria for the query
		*
		* @return the criteria
		*/
		public String getCriteria() {
			List<String> cList = new List<String>();

			if (this.accountId == null) {
				throw new APIUtils.BadException(GenericUtils.MSG_BLANK_ACCOUNTID);
			}

			cList.add('AccountId = ' + GenericUtils.quote(this.accountId));

			if (this.startDate != null) {
				cList.add('Last_Public_Case_Update_Date__c >= ' + this.startDate.formatGMT(GenericUtils.DYNAMIC_SOQL_DATE_FORMAT));
			}

			if (this.endDate != null) {
				cList.add('Last_Public_Case_Update_Date__c <= ' + this.endDate.formatGMT(GenericUtils.DYNAMIC_SOQL_DATE_FORMAT));
			}

			// We want to not include private cases unless we're asked too
			if (!this.includePrivate) {
				cList.add('Private__c = False');
			}

			// Exclude ITAR cases
			if (this.excludeITARCases) {
				cList.add('ITAR__c = False');
			}

			if (
				!this.includeClosed &&
				GenericUtils.isEmpty(this.status)
			) {
				cList.add('Status != ' + GenericUtils.quote(GenericUtils.CLOSED_STATUS));
			}

			// This method returns false if status is empty
			if (GenericUtils.isNotEmpty(this.status)) {
				if (CaseUtils.isValidStatus(this.status)) {
					cList.add('Status = ' + GenericUtils.quote(this.status));
				} else {
					throw new APIUtils.BadException(GenericUtils.MSG_INVALID_STATUS);
				}
			}

			// This method returns false if severity is empty
			if (GenericUtils.isNotEmpty(this.severity)) {
				if (CaseUtils.isValidSeverity(this.severity)) {
					cList.add('Severity__c = ' + GenericUtils.quote(this.severity));
				} else {
					throw new APIUtils.BadException(GenericUtils.MSG_INVALID_SEVERITY);
				}
			}

			// This method returns false if type is empty
			if (GenericUtils.isNotEmpty(this.type)) {
				if (CaseUtils.isValidType(this.type)) {
					cList.add('Type = ' + GenericUtils.quote(this.type));
				} else {
					throw new APIUtils.BadException(GenericUtils.MSG_INVALID_TYPE);
				}
			}

			if (GenericUtils.isNotEmpty(this.ownerSSOName)) {
				cList.add('Contact.SSO_Username__c = ' + GenericUtils.quote(this.ownerSSOName));
			}

			if (GenericUtils.isNotEmpty(this.createdBySSOName)) {
				if (this.createdBySSOName.toLowerCase() == APIUtils.REDHAT_OWNER_CONTACT_SSO_NAME.toLowerCase()) {
					cList.add('Created_By_Contact__r.SSO_Username__c = null');
				} else {
					cList.add('Created_By_Contact__r.SSO_Username__c = ' + GenericUtils.quote(this.createdBySSOName));
				}
			}

			if (GenericUtils.isNotEmptyList(this.criteriaList)) {
				for (CaseFilterCriteria criteria : this.criteriaList) {
					cList.add(criteria.getCriteria());
				}
			}

			if (GenericUtils.isNotEmpty(this.product)) {
				Product__c p = ProductUtils.getProductByName(this.product);

				cList.add('RH_Product__c = ' + GenericUtils.quote(p.Id));
			}

			if (!this.caseIds.isEmpty()) {
				List<String> escapedIds = GenericUtils.escapeIds(this.caseIds);
				cList.add('Id in (' + String.join(escapedIds, ',') + ')');
			}

			if (this.hasGroupingCriteria()) {
				List<String> escapedIds = GenericUtils.escapeIds(this.groupIds);

				String groupString = null;

				if (this.onlyInterestedInUngrouped()) {
					groupString = 'FolderId__c in (null)';
				} else {
					groupString = 'FolderId__c in (' + String.join(escapedIds, ',');

					if (this.groupNumbers.isEmpty() || this.includeUngrouped) {
						groupString += ',null';
					}

					groupString += ')';
				}

				if (GenericUtils.isNotEmpty(groupString)) {
					cList.add(groupString);
				}
			}

			String criteria = String.join(cList, ' AND ');

			return criteria;
		}

		/**
		* Gets the sort field for the Case
		*
		* @return the sort field
		*/
		public String getSortField() {
			if (
				GenericUtils.isEmpty(this.sortField) ||
				APIUtils.case_sortBlacklist.contains(this.sortField.toLowercase()) ||
				!APIUtils.case_fieldMap.containsKey(this.sortField.toLowercase())
			) {
				return GenericUtils.SORT_FIELD_DEFAULT;
			}

			return APIUtils.case_fieldMap.get(this.sortField.toLowercase());
		}

		/**
		* Gets the sort order
		*
		* @return the sort order
		*/
		public String getSortOrder() {
			if (GenericUtils.isBlank(this.sortOrder)) {
				return GenericUtils.SORT_DESC;
			}

			return (VALID_SORT_ORDERS.contains(this.sortOrder.toUppercase())) ? this.sortOrder : GenericUtils.SORT_DESC;
		}

		/**
		* Gets the sort syntax for the query
		*
		* @return the sort syntax
		*/
		public String getSort() {
			return getSortField() + ' ' + getSortOrder() + ', ' + GenericUtils.SORT_SECONDARY_DEFAULT;
		}

		/**
		* Should we reduce the information we send back
		*
		* @return if we should reduce the information we send back
		*/
		public Boolean reduceInformation() {
			return GenericUtils.isTrue(this.reducedInformation);
		}
	}

	/**
	* A class for filtering comments
