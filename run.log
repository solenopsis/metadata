	/**
	* Creates a case
	*
	* @param cContext The calling contact
	* @param apiCase The case to create
	* @return The newly created case
	*/
	// Test location CaseAPI_Test3.cls
	WebService static APIUtils.APICase createCase(APIUtils.ContactContext cContext, APIUtils.APICase apiCase) {
		UserUtils.enableCaching();
		ContactUtils.enableCaching();

		final List<Object> paramList = new List<Object> {cContext, apiCase};
		final String methodName = 'createCase';
		APIUtils.APICase result = new APIUtils.APICase();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(cContext);

			Contact callingContact = cContext.getContact();

			apiCase.ensureCase();
			apiCase.setupCase(cContext);
			apiCase.ensureContactHasManageSupportCasesPrivilege();
			apiCase.ensureHasEnhancedSLAAllotment();
			if (!cContext.isInternal) {
				apiCase.ensureCaseFolderRequirements();
			}

			Case kase = apiCase.getNewCase();
			kase.Created_By_Contact__c = callingContact.Id;
			kase.Last_Modified_By_Contact__c = callingContact.Id;
			kase.Last_Modified_By_Id__c = callingContact.Id;

			APIUtils.ensureEndpointAccess(cContext, kase);

			EmailManager.lockExternally();

			apiCase.ensureEntitlementAccountAndCaseAccount(kase);
			apiCase.setPremiumEntitlementWhenEnhancedSLAIsChecked(kase);

			Boolean isWoC = (apiCase.status == GenericUtils.WAITING_ON_CUSTOMER_STATUS);

			if (
				isWoC &&
				cContext.isInternal &&
				!CaseUtils.isSecureSupportAccount(kase)
			) {
				throw new APIUtils.InvalidPermissionsException(GenericUtils.MSG_CANNOT_SET_STATUS_WOC_BEFORE_FIRST_UPDATE);
			}

			insert kase;

			kase = CaseUtils.getCaseById(kase.Id);

			apiCase.setCase(kase);
			apiCase.insertTags();

			if (apiCase.caseResourceLinks != null) {
				apiCase.caseResourceLinks.setContact(callingContact);
				apiCase.caseResourceLinks.setCase(kase);
				apiCase.caseResourceLinks.setOrigin(KCS_Link_Utils.ORIGIN_CALAVERAS_SUGGESTION);

				if (KCSSettingsUtils.supportBothCRRAndKCSLinkSchemes()) {
					CaseResourceRelationshipManager crrManager = new CaseResourceRelationshipManager(
						apiCase.caseResourceLinks,
						callingContact,
						CaseResourceRelationshipManager.CONTEXT_CASE_CREATE
					);
					crrManager.handle();
				} else {
					Boolean allowNonInternalSolutionCreation = true;
					List<KCS_Link__c> kcsLinks = apiCase.caseResourceLinks.link(allowNonInternalSolutionCreation);

					if (!kcsLinks.isEmpty()) {
						insert kcsLinks;
					}
				}
			}

			List<Case_Comment__c> preComments = apiCase.getNewComments();

			if (!preComments.isEmpty()) {
				insert preComments;
			}

			Map<Id, Case_Comment__c> commentMap = new Map<Id, Case_Comment__c>(preComments);

			if (!((CaseUtils.looksLikeAnABRTCase(kase)) && (OrgSettingsUtils.shouldInstacloseABRTCases()))) {
				EmailManager.clearAllLocks();

				EmailManager.CaseParameter emailParam = new EmailManager.CaseParameter();
				emailParam.caseIds.add(kase.Id);
				emailParam.isNewCase = true;

				EmailManager.EmailResult emailResult = EmailManager.sendEmails(emailParam);
				emailResult.logReturnReason();
			}

			result = new APIUtils.APICase(CaseUtils.getCaseById(kase.id), cContext.isInternal);
			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (ProductUtils.InvalidNameException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (GenericUtils.InvalidPermissionsException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_FORBIDDEN;
			result.message = e.getMessage();
		} catch (GenericUtils.UnknownException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			String message = e.getMessage();

			Pattern p = Pattern.compile('.*STRING_TOO_LONG.*max length=(\\d*).*\\[(\\w*).*');
			Matcher m = p.matcher(message);
			if (m.matches()) {
				result.returnCode = APIUtils.STATUS_BAD;
				result.message = String.format(
					GenericUtils.MSG_STRING_TOO_LONG_ERROR,
					new List<String> {
						APIUtils.case_inverseFieldMap.get(m.group(2)),
						m.group(1)
					}
				);
			} else {
				result.returnCode = APIUtils.STATUS_ISE;
				result.message = e.getMessage();
			}
		} finally {
			logs.flush();
		}

		return result;
	}

	/**
	* Updates a case
	*
	* @param cContext The calling contact
	* @param apiCase The case to update
	* @return The newly updated case
	*/
	// Test location CaseAPI_Test3.cls
	WebService static APIUtils.APICase updateCase(APIUtils.ContactContext cContext, APIUtils.APICase apiCase) {
		final List<Object> paramList = new List<Object> {cContext, apiCase};
		final String methodName = 'updateCase';
		APIUtils.APICase result = new APIUtils.APICase();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(cContext);
			GenericUtils.ensureString(apiCase.CaseNumber, GenericUtils.MSG_NULL_CASE);

			Contact callingContact = cContext.getContact();

			apiCase.setupCase(cContext);
			apiCase.setCallingContact(callingContact, cContext.isInternal);

			if (GenericUtils.isTrue(apiCase.abandonCase)) {
				Case oldCase = CaseUtils.getCaseByNumber(apiCase.caseNumber);

				APIUtils.ensureEndpointAccess(cContext, oldCase);
				cContext.ensureCaseWriteAccess(oldCase);

				Case kase = CaseUtils.getAbandonedQueueCase(oldCase, callingContact);

				CaseUtils.skipTriggers();
				upsert kase;
				CaseUtils.resumeTriggers();

				result = new APIUtils.APICase(CaseUtils.getCaseByNumber(apiCase.caseNumber), cContext.isInternal);
				result.returnCode = APIUtils.STATUS_OK;
				return result;
			}

			Case kase = apiCase.getUpdateCase();

			APIUtils.ensureEndpointAccess(cContext, kase);
			cContext.ensureCaseWriteAccess(kase);

			kase.Last_Modified_By_Contact__c = callingContact.Id;
			kase.Last_Modified_By_Id__c = callingContact.Id;

			if (kase.FolderId__c != null) {
				CaseFolder__c caseGroup = AccountUtils.getGroupById(kase.FolderId__c);
				List<Group_Member__c> groupMembership = AccountUtils.getMembershipForGroup(caseGroup);
				Contact caseContact = apiCase.getContact();

				if (!AccountUtils.canAccessGroup(caseContact, caseGroup, groupMembership)) {
					throw new APIUtils.InvalidPermissionsException(GenericUtils.MSG_INVALID_GROUP_ACCESS);
				}
			}

			Boolean isWoC = (apiCase.status == GenericUtils.WAITING_ON_CUSTOMER_STATUS);
			Boolean doesNotHaveTSEComments = (kase.Public_TSE_Comments__c < 1);

			if (
				cContext.isInternal &&
				isWoC &&
				doesNotHaveTSEComments &&
				!CaseUtils.isSecureSupportAccount(kase)
			) {
				throw new APIUtils.InvalidPermissionsException(GenericUtils.MSG_CANNOT_SET_STATUS_WOC_BEFORE_FIRST_UPDATE);
			}

			CaseUtils.ensureQuestionsAreAnswered(kase);

			EmailManager.lockExternally();

			Decimal preLastPublicUpdateMS = kase.Last_Public_Case_Update_ms__c;
			Datetime preLastPublicUpdateDate = kase.Last_Public_Case_Update_Date__c;
			String preStatus = apiCase.oldStatus;
			String preSeverity = apiCase.oldSeverity;
			Boolean preMgtEscal = apiCase.oldCustomerEscalation;

			apiCase.ensureEntitlementAccountAndCaseAccount(kase);
			apiCase.setPremiumEntitlementWhenEnhancedSLAIsChecked(kase);

			CaseTriggerAfter.TARGET_DATE_LOCK = true;
			update kase;
			CaseTriggerAfter.TARGET_DATE_LOCK = false;

			apiCase.updateNEPAndMilestonesForCasesForCaseUpdate(cContext.isInternal, preStatus);

			apiCase.setCase(kase);

			kase = CaseUtils.getCaseById(kase.id);

			Decimal postLastPublicUpdateMS = kase.Last_Public_Case_Update_ms__c;
			Datetime postLastPublicUpdateDate = kase.Last_Public_Case_Update_Date__c;
			String postStatus = kase.Status;
			Boolean postMgtEscal = kase.Customer_Escalation__c;

			Set<Id> mgtEscalIds = new Set<Id>();

			if (preMgtEscal != postMgtEscal) {
				mgtEscalIds.add(kase.Id);
			}

			if (apiCase.caseResourceLinks != null) {
				apiCase.caseResourceLinks.setContact(callingContact);
				apiCase.caseResourceLinks.setCase(kase);

				if (KCSSettingsUtils.supportBothCRRAndKCSLinkSchemes()) {
					CaseResourceRelationshipManager crrManager = new CaseResourceRelationshipManager(
						apiCase.caseResourceLinks,
						callingContact,
						CaseResourceRelationshipManager.CONTEXT_CASE_UPDATE
					);
					crrManager.handle();
					// crrManager.handle(CaseResourceRelationshipManager.FROM_API);
				} else {
					Map<String, APIUtils.APICaseResourceLink> identifierToExistingCRL = new Map<String, APIUtils.APICaseResourceLink>();
					for (KCS_Link__c existingKCSLink : KCS_Link_Utils.getKCSLinksForCase(kase.id)) {
						APIUtils.APICaseResourceLink existingKCSLinkCRL = new APIUtils.APICaseResourceLink(existingKCSLink);
						identifierToExistingCRL.put(existingKCSLinkCRL.getIdentifier(), existingKCSLinkCRL);
					}

					for (APIUtils.APICaseResourceLink crl : apiCase.caseResourceLinks.caseResourceLinks) {
						// if link/pin is not persisted -or- persisted crl says linked/pinned + crl says no more:
						Boolean crlSeenBefore = identifierToExistingCRL.containsKey(crl.getIdentifier());
						if ((!crlSeenBefore) || ((crlSeenBefore) && (identifierToExistingCRL.get(crl.getIdentifier()).representsUpdate(crl)))) {
							CaseResourceLinkAPI.updateCaseResourceLink(callingContact, kase, crl);
						}
					}
				}
			}

			// COMMENTING OUT TO FIX BUG IN PORTAL.  NEED TO READDRESS
			/**
			List<Case_Comment__c> preComments = apiCase.getNewComments();

			if (!preComments.isEmpty()) {
				insert preComments;
			}
			*/


			List<Case_Comment__c> preComments = new List<Case_Comment__c>();

			if (
				(
					preLastPublicUpdateMS != postLastPublicUpdateMS ||
					preLastPublicUpdateDate != postLastPublicUpdateDate
				) ||
				!preComments.isEmpty()
			) {
				Map<Id, Case_Comment__c> commentMap = new Map<Id, Case_Comment__c>(preComments);

				EmailManager.clearAllLocks();
				EmailManager.CaseParameter emailParam = new EmailManager.CaseParameter();

				emailParam.caseIds.add(kase.Id);

				if (preStatus != kase.Status) {
					emailParam.statusChangeIds.add(kase.Id);
				}

				if (preSeverity != kase.Severity__c) {
					emailParam.severityChangeIds.add(kase.Id);
				}

				emailParam.managementEscalationIds = mgtEscalIds;
				EmailManager.EmailResult emailResult = EmailManager.sendEmails(emailParam);
				emailResult.logReturnReason();
			}

			result = new APIUtils.APICase(CaseUtils.getCaseById(kase.id), cContext.isInternal);
			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (GenericUtils.InvalidPermissionsException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_FORBIDDEN;
			result.message = e.getMessage();
		} catch (GenericUtils.UnknownException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			result.returnCode = APIUtils.STATUS_ISE;
			result.message = e.getMessage();
		} finally {
			logs.flush();
		}

		return result;
	}

