		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getFullCase(testAccount);
		testCase.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;
		testCase = TestUtils.setEntitlement(testCase, testEntitlement);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<CaseMilestone> milestones = TestUtils.getActiveCaseMilestones(testCase);

		System.assertEquals(1, milestones.size(), 'Did not get the expected number of milestones');

		CaseMilestone milestone = milestones.get(0);
		Datetime createdDate = milestone.CreatedDate;
		System.assertEquals(CaseMilestoneUtils.MILESTONE_TYPE_FIRST_RESPONSE, milestone.MilestoneType.Name, 'The active milestone should be a first response milestone');

		//This has to be done since we lock the stuff above to keep the future call from happing at the stopTest
		testCase.TargetDate__c = milestone.TargetDate;
		update testCase;

		String newDescription = TestUtils.getUniqueString('description');

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.APICase apiCase = new APIUtils.APICase();
		apiCase.caseNumber = testCase.CaseNumber;
		apiCase.description = newDescription;

		Test.startTest();

		TestUtils.clearAllLocks();
		APIUtils.APICase result = CaseAPI.updateCase(contactContext, apiCase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code back [' + result.message + ']');

		milestones = TestUtils.getActiveCaseMilestones(testCase);

		System.assertEquals(1, milestones.size(), 'Did not get the expected number of milestones');

		milestone = milestones.get(0);
		System.assertEquals(CaseMilestoneUtils.MILESTONE_TYPE_FIRST_RESPONSE, milestone.MilestoneType.Name, 'The active milestone should be a first response milestone');
		System.assertEquals(createdDate, milestone.CreatedDate, 'The milestone creation data should not have updated');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.WAITING_ON_RED_HAT_STATUS, testCase.Status, 'Did not get the right status back');
		System.assertEquals(newDescription, testCase.Description, 'Did not get the right description back');
		System.assertEquals(milestone.TargetDate, testCase.TargetDate__c, 'The target date was not set correctly');
	}

