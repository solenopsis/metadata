	static testMethod void getCase_secure_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String publicComment = '_unittest_comment_public_: 001';
		String privateComment = '_unittest_comment_private_: 001';

		Account secureAccount = TestUtils.getAccount();
		secureAccount = TestUtils.setSecureSupport(secureAccount);
		insert secureAccount;

		Case testCase = TestUtils.getDefaultCase(secureAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Case_Comment__c testPublicComment = TestUtils.getPublicComment(testCase, publicComment);
		insert testPublicComment;

		Case_Comment__c testPrivateComment = TestUtils.getPrivateComment(testCase, privateComment);
		insert testPrivateComment;

		Account internalAccount = TestUtils.getAccount();
		insert internalAccount;

		Contact internalContact = TestUtils.getContactWithSSOName(internalAccount, ssoName);
		internalContact = TestUtils.makeContactInternal(internalContact);
		internalContact = TestUtils.makeContactSecureTech(internalContact);
		insert internalContact;

		AccountAccess__c accountAccess = TestUtils.getAccountAccess(secureAccount, internalContact);
		insert accountAccess;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(internalContact);
		contactContext.securedEndpoint = true;
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');
		System.assertEquals(2, result.comments.size(), 'Did not get the right number of comments back');

		Boolean gotPublic = false;
		Boolean gotPrivate = false;

		for (APIUtils.APIComment comment : result.comments) {
			if (comment.text == publicComment) {
				gotPublic = true;
			} else if (comment.text == privateComment) {
				gotPrivate = true;
			} else {
				System.assert(false, 'Got a comment we did not expect '+comment.text);
			}
		}

		System.assert(gotPublic, 'We did not get the public comment back');
		System.assert(gotPrivate, 'We did not get the private comment back');
	}

