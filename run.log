			}

			if (this.endDate != null) {
				cList.add('Originating_System_Last_Updated_At__c < ' + this.endDate.formatGMT(GenericUtils.DYNAMIC_SOQL_DATE_FORMAT));
			}

			if (GenericUtils.isNotEmpty(this.originatingSystem)) {
				cList.add('Originating_System__c = ' + GenericUtils.quote(this.originatingSystem));
			}

			String criteria = String.join(cList, ' AND ');

			return criteria;
		}

		/**
		* Gets the field to sort by
		*
		* @return The field to sort by
		*/
		public String getSortField() {
			if (
				GenericUtils.isEmpty(this.sortField) ||
				APIUtils.etu_sortBlacklist.contains(this.sortField.toLowercase()) ||
				!APIUtils.externalTrackerUpdate_fieldMap.containsKey(this.sortField.toLowercase())
			) {
				return GenericUtils.SORT_FIELD_EXTERNAL_TRACKER_UPDATE_DEFAULT;
			}

			return APIUtils.externalTrackerUpdate_fieldMap.get(this.sortField.toLowercase());
		}

		/**
		* Gets the sort order
		*
		* @return The sort order
		*/
		public String getSortOrder() {
			if (GenericUtils.isBlank(this.sortOrder)) {
				return GenericUtils.SORT_DESC;
			}

			return (VALID_SORT_ORDERS.contains(this.sortOrder.toUppercase())) ? this.sortOrder : GenericUtils.SORT_DESC;
		}

		/**
		* Gets the sort string statement
		*
		* @return The sort statement with a default secondary sort
		*/
		public String getSort() {
			return getSortField() + ' ' + getSortOrder() + ', ' + GenericUtils.SORT_SECONDARY_EXTERNAL_TRACKER_UPDATE_DEFAULT;
		}
	}

	/**
	* A class for filter attachments
	*/
	// Test location CaseAPI_Test2.cls
	global class AttachmentFilter {
		WebService Datetime startDate;
		WebService Datetime endDate;
		WebService String sortField;
		WebService String sortOrder;
		WebService Boolean includePrivate = true;

		private Id caseId;

		/**
		* Default constructor
		*/
		public AttachmentFilter() {}

		/**
		* Sets the case Id based on a given case
		*
		* @param c The case to set
		*/
		public void setCase(Case c) {
			this.CaseId = c.Id;
		}

		/**
		* Sets booleans to avaoid NPEs
		*/
		public void setBooleans() {
			this.includePrivate = (this.includePrivate == null) ? true : this.includePrivate;
		}

		/**
		* Gets the criteria (WHERE clause) for the dynamic SOQL
		*
		* @return The where criteria
		*/
		public String getCriteria() {
			List<String> cList = new List<String>();

			GenericUtils.ensureId(this.caseId, new APIUtils.BadException(GenericUtils.MSG_BLANK_CASEID));

			cList.add('Case__c = ' + GenericUtils.quote(this.caseId));

			if (!this.includePrivate) {
				cList.add('Private__c = False');
			}

			if (this.startDate != null) {
				cList.add('LastModifiedDate >= ' + this.startDate.formatGmt(GenericUtils.DYNAMIC_SOQL_DATE_FORMAT));
			}

			if (this.endDate != null) {
				cList.add('LastModifiedDate <= ' + this.endDate.formatGmt(GenericUtils.DYNAMIC_SOQL_DATE_FORMAT));
			}

			String criteria = String.join(cList, ' AND ');

			return criteria;
		}

		/**
		* Gets the field to sort by
		*
		* @return The field to sort by
		*/
		public String getSortField() {
			if (
				GenericUtils.isEmpty(this.sortField) ||
				APIUtils.attachment_sortBlacklist.contains(this.sortField.toLowercase()) ||
				!APIUtils.attachment_fieldMap.containsKey(this.sortField.toLowercase())
			) {
				return GenericUtils.SORT_FIELD_ATTACHMENT_DEFAULT;
			}

			return APIUtils.attachment_fieldMap.get(this.sortField.toLowercase());
		}

		/**
		* Gets the sort order
		*
		* @return The sort order
		*/
		public String getSortOrder() {
			if (GenericUtils.isBlank(this.sortOrder)) {
				return GenericUtils.SORT_DESC;
			}

			return (VALID_SORT_ORDERS.contains(this.sortOrder.toUppercase())) ? this.sortOrder : GenericUtils.SORT_DESC;
		}

		/**
		* Gets the sort string statement
		*
		* @return The sort statement with a default secondary sort
		*/
		public String getSort() {
			return getSortField() + ' ' + getSortOrder() + ', ' + GenericUtils.SORT_SECONDARY_ATTACHMENT_DEFAULT;
		}
