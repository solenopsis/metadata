		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(expectedResults.size(), results.cases.size(), 'Did not get the right number of cases back');

		for (APIUtils.APICase result : results.cases) {
			System.assert(expectedResults.contains(result.Id), 'Got a result back we did not expect [' + result.summary + ']');
			expectedResults.remove(result.Id);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the results back ' + JSON.serialize(expectedResults));
	}

