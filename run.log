	static testMethod void updateCase_suggestedLink_single_valid_with_nonInternalContact() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Article__c testArticle = TestUtils.getDefaultArticle();
		insert testArticle;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		CaseFolder__c testGroup = TestUtils.getGroup(testAccount);
		insert testGroup;

		testGroup = TestUtils.fetchGroup(testGroup);

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getFullCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext context = new APIUtils.ContactContext(ssoName);
		APIUtils.APICase kase = new APIUtils.APICase();
		kase.caseNumber = testCase.CaseNumber;
		kase.alternateId = '_unittest_altid_: ' + String.valueOf(TestUtils.getRandomInteger(100000000));

		KCS_Link__c suggestedLink = TestUtils.getSuggestedKCSLink(testCase.Id, testArticle.Id);
		suggestedLink.display__c = true;
		insert suggestedLink;

		APIUtils.APICaseResourceLink link = new APIUtils.APICaseResourceLink(testArticle.KBase_URL__c);
		link.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
		link.resourceId = testArticle.Name;
		link.linked = true;

		kase.caseResourceLinks = new APIUtils.APICaseResourceLinks(new List<APIUtils.APICaseResourceLink> {link});

		Test.startTest();

		APIUtils.APICase result = CaseAPI.updateCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code [' + result.message + ']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');

		System.Debug('result: ' + result);

		System.Debug('result.caseresourcelinks: ' + result.caseresourcelinks);

		List<KCS_Link__c> kcsLinks = TestUtils.fetchKCSLinksForCase(testCase);
		System.assertEquals(1, kcsLinks.size(), 'Did not get the right number of KCS_Links back: 1');

		KCS_Link__c kcsLink = kcsLinks.get(0);

		System.assertEquals(null, kcsLink.Linked_Date__c, 'linked_Date is null because one link was done by Customer');
		System.assertEquals(null, kcsLink.Relationship_Established_By__c, 'Relationship_Established_By__c is null because one link was done by Customer');

		System.assertEquals(ssoName, kcsLink.Pinned_By_Username__c, 'pinned_By_Username__c is set to customer SSO Name');
		System.assert(TestUtils.isWithinThreshold(30 * 1000, kcsLink.pinned_Date__c.getTime(), Datetime.now().getTime()), 'pinned_Date__c within threshold');

		System.assertEquals(KCS_Link_Utils.RELATIONSHIPTYPE_PIN, kcsLink.relationshipType__c, 'Did not get the correct relationship Type');
		System.assertEquals(KCS_Link_Utils.ORIGIN_SUGGESTION, kcsLink.origin__c, 'Did not get the correct Origin');

		System.assertEquals(null, kcsLink.linkingMechanism__c, 'Did not get the correct Linking Mechanism');
		System.assertEquals(KCS_Link_Utils.PINNING_MECHANISM_STRATA, kcsLink.pinningMechanism__c, 'Did not get the correct Pinning Mechanism');
	}

