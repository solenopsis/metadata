	static testMethod void listCases_mutliWithLimit_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase1 = TestUtils.getDefaultCase(testAccount);
		insert testCase1;

		testCase1 = TestUtils.fetchCase(testCase1);

		Case testCase2 = TestUtils.getDefaultCase(testAccount);
		insert testCase2;

		testCase2 = TestUtils.fetchCase(testCase2);

		Case testCase3 = TestUtils.getDefaultCase(testAccount);
		insert testCase3;

		testCase3 = TestUtils.fetchCase(testCase3);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.AccountContext aContext = new APIUtils.AccountContext();

		CaseAPI.CaseFilter filter = new CaseAPI.CaseFilter();
		filter.maxResults = 2;

		Test.startTest();

		APIUtils.APICases result = CaseAPI.listCases(cContext, aContext, filter);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(3, result.totalCaseCount, 'Did not get the correct total case count');
		System.assertEquals(2, result.cases.size(), 'Did not get the correct number of cases back');

		Boolean gotCase1 = false;
		Boolean gotCase2 = false;
		Boolean gotCase3 = false;

		for (APIUtils.APICase kase : result.cases) {
			if (kase.caseNumber == testCase1.CaseNumber) {
				gotCase1 = true;
			} else if (kase.caseNumber == testCase2.CaseNumber) {
				gotCase2 = true;
			} else if (kase.caseNumber == testCase3.CaseNumber) {
				gotCase3 = true;
			} else {
				System.assert(false, 'Got a case we did not expect');
			}
		}

		System.assert(!gotCase1, 'Should not have gotten the first case');
		System.assert(gotCase2, 'Did not get the second case');
		System.assert(gotCase3, 'Did not get the third case');
	}

