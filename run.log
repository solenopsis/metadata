		fixedSearchResults.add(testCase2.Id);
		Test.setFixedSearchResults(fixedSearchResults);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.SearchContext sContext = new APIUtils.SearchContext(needle);

		Test.startTest();

		APIUtils.APICases result = CaseAPI.search(cContext, sContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.assertEquals(2, result.cases.size(), 'Did not get the right number of cases back');

		Boolean foundCase1 = false;
		Boolean foundCase2 = false;

		for (APIUtils.APICase c : result.cases) {
			if (c.Id == testCase1.Id) {
				foundCase1 = true;
				System.assertEquals(testCase1.Subject, c.summary, 'Got the right id but the wrong subject');
			} else if (c.Id == testCase2.Id) {
				foundCase2 = true;
				System.assertEquals(testCase2.Subject, c.summary, 'Got the right id but the wrong subject');
			} else {
				System.assert(false, 'Got a case back we didn\'t expect');
			}
		}

		System.assert(foundCase1, 'Did not find the first case');
		System.assert(foundCase2, 'Did not find the first case');
	}

