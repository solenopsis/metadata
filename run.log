	static testMethod void insertMixedCaseTagOnCaseCreate_valid(){
		// there may be an upcoming change to force all tags to be lower case, in which case this test will be obsolete
		String ssoName = TestUtils.getEmailAddress('example.com');
		String tagName = 'CamelCaseTag';
		String lcaseTagName = tagName.toLowerCase();

		Object_Tag__c tag = TestUtils.getObjectTagForCase();
		tag.Tag__c = tagName;
		insert tag;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		testAccount = TestUtils.fetchAccount(testAccount);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		insert testEntitlement;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.APICase kase = TestUtils.getAPICase(testAccount, null, null, null, testProduct, testVersion);

		String subject = kase.Summary;
		String description = kase.Description;
		kase.tags = new List<String> {lcaseTagName};

		Test.startTest();

		kase = CaseAPI.createCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code [' + kase.message + ']');

		Case result = TestUtils.fetchCase(new Case(Id = kase.Id));

		System.assertEquals(testAccount.Id, result.AccountId, 'Did not get the right account back');
		System.assertEquals(testContact.Id, result.ContactId, 'Did not get the right contact back');
		System.assertEquals(subject, result.Subject, 'Did not get the right subject back');
		System.assertEquals(description, result.Description, 'Did not get the right description back');
		System.assertEquals(tagName, result.Tags__c, 'did not get the right tags back');

		Set<String> expectedTags = new Set<String> {tagName};

		List<Case_Tag_Link__c> caseTagLinks = ObjectTagUtils.getCaseObjectTagsForCase(new Case(Id = kase.Id));
		for (Case_Tag_Link__c caseTag : caseTagLinks) {
			System.assert(expectedTags.contains(caseTag.Tag__r.Tag__c), 'unexpected tag: ' + caseTag.Tag__r.Tag__c);
			expectedTags.remove(caseTag.Tag__r.Tag__c);
		}

		System.assert(expectedTags.isEmpty(), 'did not find expected tag: ' + expectedTags);
	}

	static testMethod void createCase_fieldTooLong_invalid() {
