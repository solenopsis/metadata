		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.APICase apiCase = new APIUtils.APICase(testCase, false);
		apiCase.Status = GenericUtils.WAITING_ON_CUSTOMER_STATUS;

		startDate = Datetime.now();

		APIUtils.APICase result;

		Test.startTest();

		System.runAs(testUser) {
			result = CaseAPI.updateCase(cContext, apiCase);
		}

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code [' + result.message + ']');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.WAITING_ON_CUSTOMER_STATUS, testCase.Status, 'The status did not get updated');

