		Case result = TestUtils.fetchCase(new Case(Id = kase.Id));

		System.assertEquals(testAccount.Id, result.AccountId, 'Did not get the right account back');
		System.assertEquals(testContact.Id, result.ContactId, 'Did not get the right contact back');
		System.assertEquals(subject, result.Subject, 'Did not get the right subject back');
		System.assertEquals(description, result.Description, 'Did not get the right description back');
		System.assertEquals(APIUtils.API_ORIGIN, result.Origin, 'Did not get the right origin back');
		System.assert(result.Is_ABRT_Case_That_Should_Remain_Closed__c, 'Case should be marked as instaclosed');

		workflowEmails = TestUtils.getWorkflowEmailsSince(startDate);
		System.Debug('emails: ' + workflowEmails);
		System.assert(workflowEmails.isEmpty(), 'We should have sent no email for an ABRT case');

		List<Case_Comment__c> caseComments = CaseCommentUtils.getComments(kase.Id);
		System.Assert(!caseComments.isEmpty(), 'should have inserted a comment');
		System.assertEquals(1, caseComments.size(), 'should have one case comment');

		Case_Comment__c abrtComment = caseComments.get(0);
		System.Debug('commentBody: ' + abrtComment.Comment_Body__c);
		System.assert(
			abrtComment.Comment_Body__c.contains('This case was generated by the Automatic Bug Reporting Tool (ABRT), and this is an automated response.'),
			'does not look like automated response: ' + abrtComment.Comment_Body__c
		);
		System.assert(
			abrtComment.Comment_Body__c.contains(contactName),
			'Should contain testContact name'
		);
		System.assert(!abrtComment.Comment_Body__c.contains('{{'), 'should be no untransformed template variables'); // }}
	}

