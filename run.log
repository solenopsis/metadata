		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.FileContext fContext = new APIUtils.FileContext(hash);

		Test.startTest();

		APIUtils.APIResult result = CaseAPI.delAttachment(cContext,fContext);

