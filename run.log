		kase.caseNumber = testCase.CaseNumber;
		kase.alternateId = '_unittest_altid_: ' + String.valueOf(TestUtils.getRandomInteger(100000000));

		APIUtils.APICaseResourceLink link1 = new APIUtils.APICaseResourceLink(testArticle1.KBase_URL__c);
		APIUtils.APICaseResourceLink link2 = new APIUtils.APICaseResourceLink(testArticle2.KBase_URL__c);

		List<APIUtils.APICaseResourceLink> links = new List<APIUtils.APICaseResourceLink> {link1, link2};
		for (APIUtils.APICaseResourceLink link : links) {
			link.linked = true;
			link.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
			link.origin = KCS_Link_Utils.ORIGIN_SUGGESTION;
		}
		kase.caseResourceLinks = new APIUtils.APICaseResourceLinks(links);

		Test.startTest();

		kase = CaseAPI.updateCase(context, kase);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code [' + kase.message + ']');

		List<KCS_Link__c> results = TestUtils.fetchKCSLinksForCase(testCase);

		System.assertEquals(links.size(), results.size(), 'Did not get the right number of links back');

		Boolean gotLink1 = false;
		Boolean gotLink2 = false;

		for (KCS_Link__c result : results) {
			if (result.Article__c == testArticle1.Id) {
				gotLink1 = true;
				System.assertEquals(testArticle1.KBase_URL__c, result.KBase_URL__c, 'Did not get the right url for the first link');
			} else if (result.Article__c == testArticle2.Id) {
				System.assertEquals(testArticle2.KBase_URL__c, result.KBase_URL__c, 'Did not get the right url for the second link');
				gotLink2 = true;
			} else {
				System.assert(false, 'Got a link we were not expecting [' + result.KBase_URL__c + ']');
			}
			System.assertEquals(KCS_Link_Utils.RELATIONSHIPTYPE_PIN, result.relationshipType__c, 'Did not get the correct relationship Type');
			System.assertEquals(null, result.linkingMechanism__c, 'Linking Mechanism is null');
			System.assertEquals(KCS_Link_Utils.PINNING_MECHANISM_STRATA, result.pinningMechanism__c, 'Did not get the correct Pinning Mechanism');
			System.assertEquals(KCS_Link_Utils.ORIGIN_SUGGESTION, result.origin__c, 'Did not get the correct Origin');
		}

		System.assert(gotLink1, 'Did not get the first link');
		System.assert(gotLink2, 'Did not get the second link');
	}

