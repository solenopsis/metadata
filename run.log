	static testMethod void getCase_with_multiple_case_fields_internal() {
		String ssoName = TestUtils.getSSOName();
		String caseSummary = 'Test Case Summary';

		Account testAccount = TestUtils.getAccount();
		testAccount.No_Automation_For_Cases__c = true;
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		CaseFolder__c testGroup = TestUtils.getGroup(testAccount, 'test');
		testGroup.No_Automation_For_Cases__c = true;
		insert testGroup;

		Case testCase = TestUtils.getCase(testAccount);
		testCase.Escalate_to_GEO__c = 'APAC';
		testCase.CritSit__c = true;
		testCase.Hotfix_Requested__c = true;
		testCase.Hotfix_Delivered__c = true;
		testCase.IsPOC__c = true;
		testCase.Waiting_On_Callback__c = true;
		testCase.No_Automation_For_Case__c = true;
		testCase.FTS_Handover_Ready__c = true;
		testCase = testUtils.setCaseGroup(testCase, testGroup);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code [' + result.message + ']');
		System.assertEquals(testCase.Escalate_to_GEO__c, result.needsNewOwner, 'Did not get correct new owner region');
		System.assert(result.hotfixRequested, 'Hot fix requested should have been true.');
		System.assert(result.hotfixDelivered, 'Hot fix delivered should have been true.');
		System.assert(result.isPoc, 'Is POC should have been true.');
		System.assert(result.critSit, 'CritSit should have been true.');
		System.assert(result.waitingOnCallback, 'Waiting On Callback should have been true.');
		System.assert(!result.caseAutomationEnabled, 'automationEnabled should have been false.');
		System.assert(result.noAutomationForAccount, '"No Automation for Account" should have been true.');
		System.assert(result.noAutomationForCase, '"No Automation for Case" should have been true.');
		System.assert(result.noAutomationForCaseGroup, '"No Automation for Case Group" should have been true.');
		System.assert(result.isFTSHandoverReady, 'FTS Handover Ready flag should have been true.');
	}

