	static testMethod void addCaseContacts_bulk_SOQL_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String ssoNameBase = '_unittest_sso_bulk_: ';
		Integer contactCount = 100;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactOrgAdmin(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<Contact> contactList = new List<Contact>();

		for (Integer i = 0; i < contactCount; i++) {
			contactList.add(TestUtils.getContactWithSSOName(testAccount, ssoNameBase + i));
		}

		User stealthUser = TestUtils.createStealthUser();

		System.runAs(stealthUser) {
			insert contactList;
		}

		List<User_Case_Contact__c> uccs = TestUtils.fetchCustomerCaseContacts(testCase);

		System.assert(uccs.isEmpty(), 'There should be no case contacts');

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
		List<APIUtils.APIContact> apiContactList = new List<APIUtils.APIContact>();

		for (Contact c : contactList) {
			apiContactList.add(new APIUtils.APIContact(c));
		}

		Test.startTest();

		APIUtils.APIResult result = CaseAPI.addCaseContacts(contactContext, caseContext, apiContactList);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code back [' + result.message + ']');

		uccs = TestUtils.fetchCustomerCaseContacts(testCase);

		System.assertEquals(contactList.size(), uccs.size(), 'Did not get the expected number of case contacts back');
	}

	static testMethod void addCaseContacts_secure_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');
		String ssoNameInternal = '_unittest_sso_: 002';

		Account secureAccount = TestUtils.getAccount();
		secureAccount = TestUtils.setSecureSupport(secureAccount);
		insert secureAccount;

		CaseFolder__c testGroup = TestUtils.getGroup(secureAccount);
		insert testGroup;

		Case testCase = TestUtils.getDefaultCase(secureAccount);
		testCase = TestUtils.setCaseGroup(testCase, testGroup);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testContact = TestUtils.getContactWithSSOName(secureAccount, ssoName);
		insert testContact;

		Account internalAccount = TestUtils.getAccount();
		insert internalAccount;

		Contact internalContact = TestUtils.getContactWithSSOName(internalAccount, ssoNameInternal);
		internalContact = TestUtils.makeContactInternal(internalContact);
		internalContact = TestUtils.makeContactSecureTech(internalContact);
		insert internalContact;

		AccountAccess__c accountAccess = TestUtils.getAccountAccess(secureAccount, internalContact);
		insert accountAccess;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(internalContact);
		contactContext.securedEndpoint = true;
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
