	static testMethod void updateCertificationCase_valid() {
		String ssoName = TestUtils.getEmailAddress('example.com');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		testAccount = TestUtils.fetchAccount(testAccount);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case certificationCase = TestUtils.getCase(testAccount);
		certificationCase.ContactId = testContact.Id;
		certificationCase.RecordTypeId = GenericUtils.RECORDTYPE_ID_MAP.get(
			GenericUtils.CERTIFICATION_CASE_RECORDTYPE_NAME
		);
		insert certificationCase;

		certificationCase = TestUtils.fetchCase(certificationCase);

		String subject = certificationCase.Subject;
		String description = certificationCase.Description;

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.APICase kase = new APIUtils.APICase(certificationCase, AccountUtils.isInternal(testContact));
		kase.callingContact = testContact;
		kase.CaseNumber = certificationCase.caseNumber;
		kase.account = testAccount;

		kase = TestUtils.makeCaseIntoCertification(kase);

		Test.startTest();
		kase = CaseAPI.updateCase(context, kase);
		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code [' + kase.message + ']');

		Case result = TestUtils.fetchCase(new Case(Id = kase.Id));

		System.assertEquals(testAccount.Id, result.AccountId, 'Did not get the right account back');
		System.assertEquals(testContact.Id, result.ContactId, 'Did not get the right contact back');
		System.assertEquals(subject, result.Subject, 'Did not get the right subject back');
		System.assertEquals(description, result.Description, 'Did not get the right description back');

		System.assertEquals(GenericUtils.CERTIFICATION_CASE_RECORDTYPE_NAME, result.RecordType.Name, 'should be certification record type');
		System.assertEquals(TestUtils.DEFAULT_CERT_ARCHITECTURE, result.Cert_Architecture__c, 'Unexpected Architecture');
		System.assertEquals(TestUtils.DEFAULT_CERT_CATEGORY, result.Cert_Category__c, 'Unexpected Category');
		System.assertEquals(TestUtils.DEFAULT_CERT_VENDOR_NAME, result.Cert_Vendor_Name__c, 'Unexpected Vendor Name');
		System.assertEquals(TestUtils.DEFAULT_CERT_VENDOR_PORTAL_ID, result.Cert_Vendor_Portal_ID__c, 'Unexpected Vendor Portal Id');
		System.assertEquals(TestUtils.DEFAULT_CERT_VENDOR_PRODUCT_NAME, result.Cert_Vendor_Product_Name__c, 'Unexpected Vendor Product Name');
