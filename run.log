	static testMethod void updateCase_IGLSetsWoRHedCaseStatusToWoRH_hasNoEffect() {
		CaseMilestoneUtils.PERSIST_MILESTONES = false;

		String ssoName = TestUtils.getEmailAddress('redhat.com');

		User u = TestUtils.createTSEUser(ssoName);

		Datetime NOW = Datetime.newInstanceGMT(2015, 1, 1, 0, 0, 0);
		Datetime INITIAL_RESPONSE_MILESTONE_TARGET_DATE = Datetime.newInstanceGMT(2014, 1, 1, 0, 0, 0);
		Datetime ONGOING_RESPONSE_MILESTONE_TARGET_DATE = Datetime.newInstanceGMT(2015, 2, 1, 0, 0, 0);

		CaseTriggerBefore.SKIP_PRIORITY_SCORE_CALCULATION = true;
		CaseTriggerAfter.TARGET_DATE_LOCK = false;
		CaseTriggerAfter.USE_FUTURE_FOR_MILESTONES = false;
		CaseComment_Trigger.SKIP_SETTING_CASE_TARGET_DATE_FROM_CASE_COMMENT_TRIGGER = true;

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase = TestUtils.setEntitlement(testCase, testEntitlement);
		testCase.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;
		insert testCase;

		Case_Comment__c testComment = TestUtils.getPublicComment(testCase);
		insert testComment;

		CaseMilestoneUtils.CASE_ID_TO_CASEMILESTONE_LIST.put(testCase.Id,
			new CaseMilestoneUtils.CaseMilestoneList(
				new List<CaseMilestoneUtils.CaseMilestoneWrapper> {
					TestUtils.getCompletedFirstResponseCMW(INITIAL_RESPONSE_MILESTONE_TARGET_DATE, testCase.id),
					TestUtils.getNonCompletedOngoingResponseCMW(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.Id)
				}
			)
		);

		CaseUtils.skipTriggers();
		update new Case(Id = testCase.Id, targetDate__c = ONGOING_RESPONSE_MILESTONE_TARGET_DATE);
		CaseUtils.resumeTriggers();

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.TargetDate__c, 'target date should be ONGOING_RESPONSE_MILESTONE_TARGET_DATE');

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);

		APIUtils.APICase kase = new APIUtils.APICase();
		kase.caseNumber = testCase.CaseNumber;
		kase.status = GenericUtils.WAITING_ON_RED_HAT_STATUS;

		APIUtils.APICase caseResult;

		Test.startTest();
		System.runAs(UserUtils.getIGLIntegrationUser()) {
			TestUtils.clearAllLocks();
			caseResult = CaseAPI.updateCase(contactContext, kase);
		}
		Test.stopTest();

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(APIUtils.STATUS_OK, caseResult.returnCode, 'Did not get the right return code back [' + caseResult.message + ']');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.WAITING_ON_RED_HAT_STATUS, testCase.Status, 'The status should be WoRH');
		System.assertEquals(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, testCase.TargetDate__c, 'The targetDate should now be null');
	}

