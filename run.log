	static testMethod void addAttachmentUpdateSBTTest() {
		String testSsoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, testSsoName);
		insert testContact;

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		testEntitlement.ServiceLevel__c = 'PREMIUM';
		insert testEntitlement;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		String testSubject = 'This is a test Case';
		testCase.Subject = testSubject;
		testCase.Status = GenericUtils.WAITING_ON_CUSTOMER_STATUS;
		testCase.Internal_Status__c = GenericUtils.WAITING_ON_CUSTOMER_ISTATUS;
		testCase.Entitlement = testEntitlement;
		testCase.Severity__c = GenericUtils.SEVERITY_ONE;

		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext testCContext = new APIUtils.ContactContext(testSsoName);

		APIUtils.APIAttachments apiAttachments = new APIUtils.APIAttachments();

		Integer numberOfAttachments = 1;

		for (Integer i = 0; i < numberOfAttachments; i++) {
			APIUtils.APIAttachment apiAttachment = new APIUtils.APIAttachment();

			String fileName = 'Test ' + i;
			apiAttachment.caseNumber = testCase.caseNumber;
			apiAttachment.fileName = fileName;
			apiAttachment.link = '_unittest_attachment_link_: 001';
			apiAttachment.description = 'Description: ' + i;
			apiAttachment.size = 4028;
			apiAttachment.sizeKB = 4;

			apiAttachments.addAPIAttachment(apiAttachment);
		}

		Test.startTest();

		CaseAPI.addAttachments(testCContext, apiAttachments);

		Test.stopTest();

		if (TestUtils.getSlaProcessId(testEntitlement) == null) {
			System.debug(logginglevel.WARN, 'No SLA Process defined for entitlement ' + testEntitlement.ServiceLevel__c + '!  Skipping test!');
			return;
		}

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals('Waiting on Red Hat', testCase.Status, 'Status should have been Waiting on Red Hat');
		System.assertNotEquals(null, testCase.SBT__c, 'SBT should have been computed');
		System.assertNotEquals(null, testCase.TargetDate__c, 'Target Date should have been computed');
	}

