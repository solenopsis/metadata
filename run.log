		externalTrackerUpdateFilter.sortField = 'publisheddate';
		externalTrackerUpdateFilter.sortOrder = GenericUtils.SORT_DESC;

		Test.startTest();

		APIUtils.APIExternalTrackerUpdates results = CaseAPI.listExternalTrackerUpdatesWithFilter(contactContext, caseContext, externalTrackerUpdateFilter);

