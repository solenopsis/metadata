		System.assert(newComment.Is_Public__c, 'Did not get the right public status back');
		System.assert(!newComment.Is_Draft__c, 'Did not get the right draft status back');
		System.assertEquals(testContact.Id, newComment.Created_By_Contact__c, 'Did not get t he right created by');

		List<WorkflowEmail__c> emails = TestUtils.getWorkflowEmailsSince(startTime);
		System.assertEquals(2, emails.size(), 'Did not get the expected number of emails');

		Boolean gotInternalEmail = false;
		Boolean gotExternalEmail = false;

		for (WorkflowEmail__c email : emails) {
			String expectedURL;

			if (email.To_List__c.contains(testOwner.Email)) {
				gotInternalEmail = true;
				expectedURL = GenericUtils.ENVIRONMENT_URL + testCase.Id + '#comment_' + result.Id;
			} else if (email.To_List__c.contains(testContact.Email)) {
				gotExternalEmail = true;
				expectedURL = GenericUtils.AVALON_URL + '#/case/' + testCase.CaseNumber + '?commentId=' + result.Id;
			} else {
				System.assert(false, 'Got an email to a recipient we did not expect ' + JSON.serialize(email));
			}

			System.assert(email.Subject__c.containsNone('{!'), 'Did not get all of the substitutions in the subject');
			System.assert(email.Body__c.containsNone('{!'), 'Did not get all of the substitutions in the body');
			System.assert(email.Body__c.contains(expectedURL), 'Could not find the expected comment url in the body - Looking for ' + expectedURL + ' in ' + JSON.serialize(email));
		}

		System.assert(gotInternalEmail, 'Did not get the internal email');
		System.assert(gotExternalEmail, 'Did not get the internal email');
	}

