	static testMethod void notificationAddressSendOnPublicUpdate() {
		String emailAddress = TestUtils.getEmailAddress('redhat.com');
		String ssoName = TestUtils.getEmailAddress('redhat.com');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = Testutils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		testCase.Severity__c = GenericUtils.SEVERITY_FOUR;
		insert testCase;

		NotificationAddress__c notificationAddress = TestUtils.getNotificationAddress(testAccount, emailAddress);
		notificationAddress.Minimum_Severity__c = '4';
		insert notificationAddress;

		testCase = TestUtils.fetchCase(testCase);
		Case_Comment__c testComment = TestUtils.getPublicComment(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.APIComment apiComment = new APIUtils.APIComment(testComment);
		apiComment.caseNumber = testCase.CaseNumber;

		Datetime startDate = Datetime.now();
		TestUtils.clearWorkflowEmails(startDate);
		EmailManager.clearAllLocks();

		Test.startTest();

		APIUtils.APIComment result = CaseAPI.upsertCaseComment(contactContext, apiComment);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the expected return code [' + result.message + ']');
		List<WorkflowEmail__c> workflowEmails = TestUtils.getWorkflowEmailsSince(startDate);
		System.assertEquals(1, workflowEmails.size(), 'We should have sent exactly 1 email');
		System.assert(workflowEmails.get(0).To_List__c.contains(emailAddress), 'We did not send an email to the expected address');
		System.assert(workflowEmails.get(0).Body__c.contains('A comment has been added to the case'), 'Did not get the right email template');
	}

