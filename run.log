* Test class for CaseAPI getCase with Bugs
*
* @author Daniel Fisher (dfisher@redhat.com)
*/

@isTest
private class CaseAPI_getCase_withBugs_Test {
	@TestSetup
	static void setUp() {
		TestUtils.setupProductAndVersion();
	}

	static testMethod void getCase_withNoPublicBugzillasNoPartnerBugzillasNoInternalBugzillas_viaNonInternalContact_valid() {
		final String BZ_CONFIDENTIAL_GROUP = 'llnl';

		String ssoName = TestUtils.getUniqueString('Non-Internal');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testNonInternalContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert new List<Contact>{testNonInternalContact};

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testNonInternalContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();
		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);
		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(testCase.caseNumber, result.caseNumber, 'Did not get the same case number back');

		System.AssertEquals(0, result.bugs.size(), 'zero bugs should be seen');
	}

