		Case testCase2 = TestUtils.getCase(testAccount);
		testCase2 = TestUtils.setStatus(testCase2, GenericUtils.WAITING_ON_CUSTOMER_STATUS);

		Case testCase3 = TestUtils.getCase(testAccount);
		testCase3 = TestUtils.setStatus(testCase3, GenericUtils.CLOSED_STATUS);

		List<Case> testCases = new List<Case>{testCase1, testCase2, testCase3};
		insert testCases;

		for (Case testCase : testCases) {
			if (testCase.Subject == testCase1.Subject) {
				testCase1 = testCase;
			} else if (testCase.Subject == testCase2.Subject) {
				testCase2 = testCase;
			} else if (testCase.Subject == testCase3.Subject) {
				testCase3 = testCase;
			}
