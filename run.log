				gotCase2 = true;
			} else if (kase.caseNumber == testCase3.CaseNumber) {
				gotCase3 = true;
			} else {
				System.assert(false, 'Got a case we did not expect');
			}
		}

		System.assert(gotCase1, 'Did not get the first case');
		System.assert(!gotCase2, 'Should not have gotten the second case');
		System.assert(!gotCase3, 'Should not have gotten the third case');
	}

