		String subject = TestUtils.getUniqueString('this is a subject');
		String description = TestUtils.getUniqueString('this is a description');

		String ssoName = TestUtils.getEmailAddress('redhat.com');
		User strataUser = TestUtils.getStrataUser();

		String solutionDisplayId1 = TestUtils.getUniqueString('T123');
		String solutionDisplayId2 = TestUtils.getUniqueString('T888');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		User testUser = TestUtils.createTseUser(ssoName);

		Entitlement testEntitlement = TestUtils.getEntitlement('_unittest_name_: 001', testAccount);
		insert testEntitlement;

		Product__c testProduct = TestUtils.getRHProduct();
		insert testProduct;

		Version__c testVersion = TestUtils.getRHVersion(testProduct);
		insert testVersion;

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.APICase apiCase = TestUtils.getAPICase(testProduct, testVersion);
		apiCase.summary = subject;
		apiCase.description = description;

		APIUtils.APICaseResourceLink crl1 = new APIUtils.APICaseResourceLink();
		crl1.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
		crl1.resourceUri = GenericUtils.solution_resource_uri(solutionDisplayId1);
		crl1.resourceId = solutionDisplayId1;
		crl1.linked = true;

		APIUtils.APICaseResourceLink crl2 = new APIUtils.APICaseResourceLink();
		crl2.resourceType = APIUtils.SOLUTION_RESOURCE_TYPE;
		crl2.resourceUri = GenericUtils.solution_resource_uri(solutionDisplayId2);
		crl2.resourceId = solutionDisplayId2;
		crl2.linked = true;

		List<APIUtils.APICaseResourceLink> links = new List<APIUtils.APICaseResourceLink> {crl1, crl2};
		apiCase.caseResourceLinks = new APIUtils.APICaseResourceLinks(links);

		Test.startTest();
		System.assertEquals(0, Limits.getQueries(), 'should have no queries called at this point');
		System.runAs(strataUser) {
			apiCase = CaseAPI.createCase(context, apiCase);
		}
		System.assert(Limits.getQueries() + SPARE_QUERIES <= Limits.getLimitQueries(), 'Unexpected high number of queries made: ' + Limits.getQueries());
		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, apiCase.returnCode, 'Did not get the right return code [' + apiCase.message + ']');

		Case persistedCase = TestUtils.fetchCase(new Case(Id = apiCase.Id));

		System.assertEquals(testAccount.Id, persistedCase.AccountId, 'Did not get the right account back');
		System.assertEquals(testContact.Id, persistedCase.ContactId, 'Did not get the right contact back');
		System.assertEquals(subject, persistedCase.Subject, 'Did not get the right subject back');
		System.assertEquals(description, persistedCase.Description, 'Did not get the right description back');

		List<Case_Resource_Relationship__c> crrs = CaseResourceRelationshipUtils.caseResourceRelationshipListForCaseId(persistedCase.Id);
		System.assertEquals(2, crrs.size(), 'there should be two crrs for case');

		Set<String> expectedUris = new Set<String> {
			GenericUtils.solution_resource_uri(solutionDisplayId1),
			GenericUtils.solution_resource_uri(solutionDisplayId2)
		};
		for (Case_Resource_Relationship__c crr : crrs) {
			System.assert(expectedUris.contains(crr.Resource_URI__c), 'unexpected uri: ' + crr.Resource_URI__c);
			expectedUris.remove(crr.Resource_URI__c);

			System.assertEquals(CaseResourceRelationshipManager.TYPE_LINK, crr.Type__c, 'type should be link');
			System.assertEquals(CaseResourceRelationshipUtils.LINKING_MECHANISM_STRATA, crr.Linking_Mechanism__c, 'linking mechanism should be strata');

			System.assertEquals(null, crr.Pinning_Mechanism__c, 'pinning mechanism should be null');
			System.assertEquals(null, crr.Pinned_At__c, 'pinned at should be null');
		}

		System.assert(expectedUris.isEmpty(), 'did not find expected uris: ' + expectedUris);
	}
}
