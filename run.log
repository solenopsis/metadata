		insert TestUtils.getPublicComment(testCase, 'InitialPublicComment');

		testCase = TestUtils.fetchCase(testCase);

		Datetime startDate = Datetime.now();
		TestUtils.clearWorkflowEmails(startDate);

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		cContext.securedEndpoint = true;

		APIUtils.APICase apiCase = new APIUtils.APICase(testCase, false);
		apiCase.Status = GenericUtils.WAITING_ON_CUSTOMER_STATUS;

		startDate = Datetime.now();

		APIUtils.APICase result;

		System.runAs(testUser) {
			Test.startTest();

			result = CaseAPI.updateCase(cContext, apiCase);

			Test.stopTest();
		}

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code [' + result.message + ']');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.WAITING_ON_CUSTOMER_STATUS, testCase.Status, 'The status did not get updated');

		List<WorkflowEmail__c> emails = TestUtils.getWorkflowEmailsSince(startDate);
		List<Map<String, String>> emailData = new List<Map<String, String>>();
		for (WorkflowEmail__c email : emails) {
			emailData.add(new Map<String, String> {
				'Subject' => email.Subject__c,
				'To' => email.To_List__c
			});
		}
		System.assertEquals(1, emails.size(), 'Did not send the right number of emails: ' + JSON.serialize(emailData));
		System.assert(emails.get(0).Body__c.containsIgnoreCase('case has been updated'), 'Did not get the right template back');
		System.assert(emails.get(0).Body__c.contains(GenericUtils.getSecureCaseLink(testCase)), 'Email did not contain url for the portal');
		System.assert(!emails.get(0).Body__c.containsIgnoreCase('case has transitioned to'), 'The incorrect email was sent [' + emails.get(0).Body__c + ']');
		System.assert(!emails.get(0).Body__c.containsIgnoreCase(GenericUtils.WAITING_ON_CUSTOMER_STATUS), 'The email should not have had the new status in it [' + emails.get(0).Body__c + ']');
	}

