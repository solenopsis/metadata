	static testMethod void update_partnerprivate_valid() {
		String caseCommentUpdaterSSOName = TestUtils.getEmailAddress('redhat.com');
		String caseCommentCreatorSSOName = TestUtils.getEmailAddress('redhat.com');

		User originalCommentCreator = TestUtils.createTSEUser(caseCommentCreatorSSOName);
		User commentUpdaterUser = TestUtils.createTSEUser(caseCommentUpdaterSSOName);

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		External_Tracker__c testTracker1 = TestUtils.getExternalTracker(testCase);
		testTracker1.System__c = TestUtils.getUniqueString('system_name');
		testTracker1.System_Instance__c = TestUtils.getUniqueString('system_instance');
		testTracker1.Ticket_Reference__c = TestUtils.getUniqueString('reference');

		External_Tracker__c testTracker2 = TestUtils.getExternalTracker(testCase);
		testTracker2.System__c = TestUtils.getUniqueString('system_name');
		testTracker2.System_Instance__c = TestUtils.getUniqueString('system_instance');
		testTracker2.Ticket_Reference__c = TestUtils.getUniqueString('reference');

		insert new List<External_Tracker__c> {testTracker1, testTracker2};

		testTracker1 = TestUtils.fetchExternalTracker(testTracker1);

		Case_Comment__c testComment = TestUtils.getPrivateComment(testCase);
		testComment = TestUtils.setCommentOwner(testComment, originalCommentCreator);
		testComment.External_Tracker_To_Partner_Private_Map__c = JSON.serialize(new Map<Id, Boolean> {testTracker2.Id => false});
		insert testComment;

		testComment = TestUtils.fetchComment(testComment);

		Account internalAccount = TestUtils.getAccount();
		insert internalAccount;

		Contact internalContact = TestUtils.getContactWithSSOName(internalAccount, caseCommentUpdaterSSOName);
		internalContact = TestUtils.makeContactInternal(internalContact);
		insert internalContact;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(internalContact);
		APIUtils.APIComment apiComment = new APIUtils.APIComment(testComment);
		apiComment.sharePrivateWithExternalTrackers = new List<String> {testTracker1.Name};
		apiComment.isDraft = false;

		Test.startTest();

		APIUtils.APIComment result = InternalAPI.upsertCaseComment(contactContext, apiComment);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code back [' + result.message + ']');

		String trackerJson = JSON.serialize(new Map<Id, Boolean> {testTracker1.Id => true});

		Case_Comment__c newComment = TestUtils.fetchComment(new Case_Comment__c(Id = result.Id));

		System.assertEquals(testCase.Id, newComment.Case__c, 'Did not get assigned to the right case');
		System.assertEquals(testComment.Comment_Body__c, newComment.Comment_Body__c, 'Did not get the right body back');
		System.assert(!newComment.Is_Public__c, 'Did not get the right public status back');
		System.assert(!newComment.Is_Draft__c, 'Did not get the right draft status back');
		System.assertEquals(null, newComment.Created_By_Contact__c, 'Did not get the right created by');
		System.assertEquals(originalCommentCreator.Id, newComment.Created_By_User__c, 'Did not get the right created by');
		System.assertEquals(null, newComment.Last_Modified_By_Contact__c, 'Did not get the right last modified by');
		System.assertEquals(commentUpdaterUser.Id, newComment.Last_Modified_By_User__c, 'Did not get the right last modified by');
		System.assertEquals(trackerJson, newComment.External_Tracker_To_Partner_Private_Map__c, 'Did not get the right sharing map back');
	}

