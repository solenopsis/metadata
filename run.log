/**
* Test class for CaseAPI getTags method
*
* @author Patrick Connelly (pconnell@redhat.com)
*/

@isTest
private class CaseAPI_getTags_Test {
	//////////////////////////////////////////////////////////////////////////
	//                             getTags                                  //
	//////////////////////////////////////////////////////////////////////////

	static testMethod void getTags_valid() {
		List<Object_Tag__c> caseTags = new List<Object_Tag__c>();

		for (Integer i = 0; i < 500; i++) {
			Object_Tag__c objectTag = TestUtils.getObjectTagForCase();
			objectTag.Tag__c += String.valueOf(i);
			caseTags.add(objectTag);
		}

		insert caseTags;

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.getTags();

		Test.stopTest();

		Set<String> expectedResults = new Set<String>();

		for (Object_Tag__c tag : caseTags) {
			expectedResults.add(tag.Tag__c);
		}

		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code ['+results.message+']');
		System.assertEquals(expectedResults.size(), results.values.size(), 'Did not get the right number of tags back');

		for (String tag : results.values) {
			System.assert(expectedResults.contains(tag), 'Got a tag we did not expect ['+tag+']');
			expectedResults.remove(tag);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the tags we expected ['+expectedResults+']');
	}

	static testMethod void getTags_ise_invalid() {
		APIUtils.THROW_EXCEPTION = true;

		Test.startTest();

		APIUtils.APIPicklist results = CaseAPI.getTags();

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_ISE, results.returnCode, 'Did not get the right return code ['+results.message+']');
		System.assertEquals(GenericUtils.MSG_ISE, results.message, 'Got the right return code but the wrong message');
	}
}
