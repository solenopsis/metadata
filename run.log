		System.assertEquals(APIUtils.STATUS_OK, results.returnCode, 'Did not get the right return code [' + results.message + ']');
		System.assertEquals(expectedBodies.size(), results.externalTrackerUpdates.size(), 'Did not get the right number of external tracker updates back');

		for (Integer i = 0; i < expectedBodies.size(); i++) {
			System.assertEquals(expectedBodies.get(i), results.externalTrackerUpdates.get(i).body, 'Did not get the right body back');
		}
	}

