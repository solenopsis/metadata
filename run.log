	static testMethod void getCase_liveChatTranscripts_nonOrgAdmin_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		LiveChatVisitor testVisitor = TestUtils.getLiveChatVisitor();
		insert testVisitor;

		LiveChatTranscript testTranscript = TestUtils.getLiveChatTranscript(testVisitor);
		testTranscript = TestUtils.setContact(testTranscript, testContact);
		testTranscript = TestUtils.setCase(testTranscript, testCase);
		insert testTranscript;

		testTranscript = TestUtils.fetchLiveChatTranscript(testTranscript);

		Contact otherContact = TestUtils.getContact(testAccount);
		insert otherContact;

		LiveChatVisitor otherVisitor = TestUtils.getLiveChatVisitor();
		insert otherVisitor;

		LiveChatTranscript otherTranscript = TestUtils.getLiveChatTranscript(otherVisitor);
		otherTranscript = TestUtils.setContact(otherTranscript, otherContact);
		otherTranscript = TestUtils.setCase(otherTranscript, testCase);
		insert otherTranscript;

		otherTranscript = TestUtils.fetchLiveChatTranscript(otherTranscript);

		APIUtils.ContactContext callingContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(callingContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');
		System.assertEquals(1, result.transcripts.size(), 'Did not get the correct number of transcripts back');
		System.assertEquals(testTranscript.Body, result.transcripts.get(0).body, 'Body does not match');
		System.assertEquals(testTranscript.RequestTime, result.transcripts.get(0).requestTime, 'Request time does not match');
		System.assertEquals(testTranscript.StartTime, result.transcripts.get(0).startTime, 'Start time does not match');
