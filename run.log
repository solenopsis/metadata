	static testMethod void upsertCaseComment_email_valid() {
		User strataUser = TestUtils.getStrataUser();
		User testOwner = TestUtils.createTSEUser(TestUtils.getEmailAddress('test.redhat.org'));

		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount, testContact);
		testCase.OwnerId = testOwner.Id;
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Case_Comment__c testComment = TestUtils.getPublicComment(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.APIComment apiComment = new APIUtils.APIComment(testComment);
		apiComment.caseNumber = testCase.CaseNumber;

		Datetime startTime = Datetime.now();
		TestUtils.clearWorkflowEmails(startTime);

		EmailManager.clearAllLocks();

		Test.startTest();

		APIUtils.APIComment result;

		System.runAs(strataUser) {
			result = CaseAPI.upsertCaseComment(contactContext, apiComment);
		}

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right re turn code back [' + result.message + ']');

		Case_Comment__c newComment = TestUtils.fetchComment(new Case_Comment__c(Id = result.Id));

		System.assertEquals(testCase.Id, newComment.Case__c, 'Did not get assigned to the ri ght case');
		System.assertEquals(testComment.Comment_Body__c, newComment.Comment_Body__c, 'Did no t get the right body back');
		System.assert(newComment.Is_Public__c, 'Did not get the right public status back');
		System.assert(!newComment.Is_Draft__c, 'Did not get the right draft status back');
		System.assertEquals(testContact.Id, newComment.Created_By_Contact__c, 'Did not get t he right created by');

		List<WorkflowEmail__c> emails = TestUtils.getWorkflowEmailsSince(startTime);
		System.assertEquals(2, emails.size(), 'Did not get the expected number of emails');

		Boolean gotInternalEmail = false;
		Boolean gotExternalEmail = false;

		for (WorkflowEmail__c email : emails) {
			String expectedURL;

			if (email.To_List__c.contains(testOwner.Email)) {
				gotInternalEmail = true;
				expectedURL = GenericUtils.ENVIRONMENT_URL + testCase.Id + '#comment_' + result.Id;
			} else if (email.To_List__c.contains(testContact.Email)) {
				gotExternalEmail = true;
				expectedURL = GenericUtils.AVALON_URL + '#/case/' + testCase.CaseNumber + '?commentId=' + result.Id;
