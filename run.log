	// Test location CaseAPI_Test1.cls
	WebService static APIUtils.APIResult addCaseContacts(APIUtils.ContactContext cContext, APIUtils.CaseContext caseContext, List<APIUtils.APIContact> contacts) {
		final List<Object> paramList = new List<Object> {cContext, caseContext, contacts};
		final String methodName = 'addCaseContacts';
		APIUtils.APIResult result = new APIUtils.APIResult();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(cContext);
			APIUtils.ensureCaseContext(caseContext);
			GenericUtils.ensureList(contacts, GenericUtils.MSG_NULL_CONTACTLIST);

			Contact contact = cContext.getContact();
			Case kase = CaseUtils.getCaseByNumber(caseContext.caseNum);

			APIUtils.ensureEndpointAccess(cContext, kase);
			cContext.ensureCaseWriteAccess(kase);

			APIUtils.AccountContext accountContext = new APIUtils.AccountContext(kase.Account.AccountNumber);
			accountContext.processContact(contact);

			List<String> ssoNames = APIUtils.getSSONames(contacts);
			Map<Id, Contact> contactMap = new Map<Id, Contact>(AccountUtils.getContacts(ssoNames));

			if (!cContext.isInternal && !cContext.isOrgAdmin && !accountContext.isPartner) {
				Boolean addingOwnContact = contactMap.containsKey(contact.Id);
				contactMap.clear();

				if (addingOwnContact) {
					contactMap.put(contact.Id, contact);
				}
			}

			if (!contactMap.isEmpty()) {
				Map<Id, List<Group_Member__c>> contactToMemberMap = AccountUtils.getMembershipForContacts(contactMap.keySet());
				List<Contact> contactsToAdd = new List<Contact>();

				List<Account> accounts = AccountUtils.getCustomerAccountsFromId(contact.AccountId);
				for (Contact caseContact : contactMap.values()) {
					try {
						APIUtils.ensureCaseAccess(kase, caseContact, AccountUtils.isInternal(caseContact), contactToMemberMap.get(caseContact.Id), accounts);
						contactsToAdd.add(caseContact);
					} catch (APIUtils.InvalidPermissionsException e) {
						GenericUtils.reportException('Contact "' + caseContact + '" does not have permission', e, GenericUtils.DEBUG);
					}
				}

				if (!contactsToAdd.isEmpty()) {
					CaseUtils.addCaseContacts(kase, contactsToAdd);
				}
			}

			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (GenericUtils.InvalidPermissionsException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_FORBIDDEN;
			result.message = e.getMessage();
		} catch (GenericUtils.UnknownException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			result.returnCode = APIUtils.STATUS_ISE;
			result.message = e.getMessage();
		} finally {
			logs.flush();
		}

		return result;
	}

