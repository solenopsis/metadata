	/**
	* Searches cases and comments for the given search string
	*
	* @param cContext The calling contact context
	* @param sContext The search context
	* @return A list of cases with their comments that match
	*/
	// Test location CaseAPI_Test1.cls
	WebService static APIUtils.APICases search(APIUtils.ContactContext cContext, APIUtils.SearchContext sContext) {
		final List<Object> paramList = new List<Object> {cContext, sContext};
		final String methodName = 'search';
		APIUtils.APICases result = new APIUtils.APICases();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(cContext);
			APIUtils.ensureSearchContext(sContext);

			result.cases = new List<APIUtils.APICase>();

			Map<String, List<sObject>> searchResults = CaseUtils.searchCasesAndComments(cContext.getContact().AccountId, sContext.searchString);

			if (!searchResults.isEmpty()) {
				Set<Id> caseIds = new Set<Id>();
				Set<Id> commentIds = new Set<Id>();

				String caseSObjectName = Case.sObjectType.getDescribe().getName();

				if (searchResults.containsKey(caseSObjectName)) {
					for (sObject c : searchResults.get(caseSObjectName)) {
						caseIds.add((Id) c.get('Id'));
					}
				}

				String commentSObjectName = Case_Comment__c.sObjectType.getDescribe().getName();

				// It is possible for us to not have any comments match.  Check before to make sure we don't NPE
				if (searchResults.containsKey(commentSObjectName)) {
					for (sObject comment : searchResults.get(commentSObjectName)) {
						caseIds.add((Id) comment.get('Case__c'));
						commentIds.add((Id) comment.get('Id'));
					}
				}

				List<Case> cases = CaseUtils.getCasesByIdsReduced(caseIds);
				Map<Id, List<Case_Comment__c>> caseToCommentMap = new Map<Id, List<Case_Comment__c>>();

				if (!commentIds.isEmpty()) {
					for (Case_Comment__c comment : CaseUtils.getCommentsByIds(commentIds)) {
						if (!caseToCommentMap.containsKey(comment.Case__c)) {
							caseToCommentMap.put(comment.Case__c, new List<Case_Comment__c>());
						}

						caseToCommentMap.get(comment.Case__c).add(comment);
					}
				}

				Set<Id> groupIds = new Set<Id>();
				for (CaseFolder__c g : AccountUtils.getGroupsForContact(cContext.getContact())) {
					groupIds.add(g.Id);
				}

				Integer caseCount = cases.size();
				for (Integer i = 0; i < caseCount; i += 1) {
					Case c = cases.remove(0);
					if (
							(
								c.FolderId__c == null ||
								groupIds.contains(c.FolderId__c)
							) && (
								!CaseUtils.isClosed(c) ||
								sContext.includeClosed
							)
					) {
						APIUtils.APICase apiCase = new APIUtils.APICase(c, cContext.isInternal, true);

						if (caseToCommentMap.containsKey(c.Id)) {
							apiCase.comments = new List<APIUtils.APIComment>();

							for (Case_Comment__c comment : caseToCommentMap.get(c.Id)) {
								apiCase.comments.add(new APIUtils.APIComment(comment));
							}
						}

						result.cases.add(apiCase);
					}
				}
			}

			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (AccountUtils.UnknownContactException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			result.returnCode = APIUtils.STATUS_ISE;
			result.message = e.getMessage();
		} finally {
			logs.flush();
		}

		return result;
	}

	/**
	* Get a List of cases for a given contact
	*
	* @param cContext The calling contact context
	* @param aContext The account context
	* @param cFilter The Filter criteria
	* @return A list of cases
	*/
	// Test location CaseAPI_Test1.cls
	WebService static APIUtils.APICases listCases(APIUtils.ContactContext cContext, APIUtils.AccountContext aContext, CaseFilter cFilter) {
		final List<Object> paramList = new List<Object> {cContext, aContext, cFilter};
		final String methodName = 'listCases';
		APIUtils.APICases result = new APIUtils.APICases();

		Loggly.BATCH_LOGS = true;
		Loggly logs = new Loggly();

		try {
			APIUtils.generateExceptionForTesting();
			APIUtils.ensureContactContext(cContext);

			if (cFilter == null) {
				cFilter = new CaseFilter();
			}

			cFilter.setBooleans();

			Contact contact = cContext.getContact();

			// Hide private cases from non-internal contacts
			if (!cContext.isInternal) {
				cFilter.includePrivate = false;
			}

			// Exclude ITAR cases for non ITAR internal contacts
			if (!AccountUtils.canAccessITARCases(contact, cContext.isInternal)) {
				cFilter.excludeITARCases = true;
			}

			if (aContext == null) {
				aContext = new APIUtils.AccountContext();
			}
			aContext.processContact(contact);
			Account acct = aContext.getAccount();
			List<Account> partAccounts = aContext.getPartnerAccounts();

			APIUtils.ensureEndpointAccess(cContext, acct);
			if (!aContext.isPartner) {
				APIUtils.ensureAccountAccess(contact, acct, cContext.isInternal);
			}

			if (GenericUtils.isNotEmpty(cFilter.ownerSSOName)) {
				Contact owner = AccountUtils.getContact(cFilter.ownerSSOName);
				APIUtils.ensureAccountSameness(acct, owner, cContext.isInternal);
			}

			// If createdBySSOName is specified verify that the contact with that SSOName is either a member of the
			// account or a member of one of the partner accounts (if the case was created by a partner).
			if (GenericUtils.isNotEmpty(cFilter.createdBySSOName)) {
				if (cFilter.createdBySSOName.toLowerCase() != APIUtils.REDHAT_OWNER_CONTACT_SSO_NAME.toLowerCase()) {
					Contact creator = AccountUtils.getContact(cFilter.createdBySSOName);
					APIUtils.ensureAccountSameness(acct, creator, partAccounts, cContext.isInternal);
				}
			}

			List<Group_Member__c> groupMembership = new List<Group_Member__c>();

			// Don't use the contact group membership for a partner account
			if (!aContext.isPartner) {
				try {
					groupMembership = AccountUtils.getMembershipForContact(contact);
				} catch (Exception e) {
					// If for some reason this fails, it's ok, we'll just assume
					//   they don't have a membership
					GenericUtils.reportException('Unable to get group membership', e, true, GenericUtils.DEBUG);
				}
			}

			// We want to filter by group.  Lets make sure they exist, and that
			//   the contact has access to it.
			if (!cFilter.groupNumbers.isEmpty()) {
				Set<String> groupNumberSet = new Set<String>();
				groupNumberSet.addAll(cFilter.groupNumbers);
				Map<String, CaseFolder__c> groupMap = CaseUtils.getGroupsByNumber(groupNumberSet);

				for (String groupNum : cFilter.groupNumbers) {
					if (groupNum == GenericUtils.GROUP_UNSET) {
						cFilter.includeUngrouped = true;
					} else if (!groupMap.containsKey(groupNum)) {
						throw new GenericUtils.UnknownException(GenericUtils.MSG_UNKNOWN_GROUP + ' [' + groupNum + ']');
					}
				}

				// Don't worry about group access for a partner account
				if (!aContext.isPartner && !AccountUtils.canAccessAllGroups(contact, groupMap.values(), groupMembership)) {
					throw new APIUtils.InvalidPermissionsException(GenericUtils.MSG_INVALID_GROUP_PERMISSION);
				}

				Map<Id, CaseFolder__c> idToGroupMap = new Map<Id, CaseFolder__c>(groupMap.values());
				cFilter.groupIds = new Set<Id>();
				cFilter.groupIds.addAll(idToGroupMap.keySet());
			}

			// Lets search the cases for the keyword if we have it.  Then add it
			//   to the filter so it'll get added to our SOQL
			if (GenericUtils.isNotEmpty(cFilter.keyword)) {
				cFilter.caseIds = CaseUtils.getCaseIdsForSearch((String) acct.Id, cFilter.keyword);
			}

			Map<Id, List<Case_Comment__c>> caseToCommentMap = new Map<Id, List<Case_Comment__c>>();

			if (!GenericUtils.isEmptyList(cFilter.commentIds)) {
				try {
					caseToCommentMap = CaseUtils.getCaseToCommentMap(new Set<Id>(cFilter.commentIds));
					cFilter.caseIds.addAll(caseToCommentMap.keySet());
				} catch (APIUtils.UnknownCommentException e) {
					GenericUtils.reportException('listCase', e, GenericUtils.WARN);
				}
			}

			if (!GenericUtils.isEmptyList(cFilter.caseNumbers)) {
				cFilter.caseNumbers = GenericUtils.padCaseNumbers(cFilter.caseNumbers);

				try {
					cFilter.caseIds.addAll(CaseUtils.getCaseMapForCaseNumbers(new Set<String>(cFilter.caseNumbers)).keySet());
				} catch (APIUtils.UnknownCaseException e) {
					GenericUtils.reportException('listCase', e, GenericUtils.WARN);
				}
			}

			// If we have comments we are looking for or case numbers, but we don't
			//   have case ids (ie we didn't find what we were looking for, then we
			//   want to short circuit the query by looking for a null id
			Boolean hasCommentFilter = !GenericUtils.isEmptyList(cFilter.commentIds);
			Boolean hasCaseFilter = !GenericUtils.isEmptyList(cFilter.caseNumbers);
			Boolean foundCases = !cFilter.caseIds.isEmpty();

			if ((hasCommentFilter || hasCaseFilter) && !foundCases) {
				cFilter.caseIds.add(null);
			}

			// If the contact is restricted by ACLs, let's pre-filter those too
			if (
				!cContext.isOrgAdmin &&
				!cContext.isInternal &&
				!aContext.isPartner &&
				AccountUtils.hasACLsEnabled(acct) &&
				cFilter.groupIds.isEmpty()
			) {
				if (groupMembership.isEmpty()) {
					cFilter.onlyUngrouped = true;
				} else {
					for (Group_Member__c member : groupMembership) {
						cFilter.groupIds.add(member.Group__c);
					}
				}
			}

			// Reduce the field set if requested
			if (cFilter.reduceInformation()) {
				for (String key : APIUtils.case_fieldsToReduce) {
					APIUtils.case_fieldMap.remove(key);
				}
			}

			String fields = APIUtils.getCaseFieldsForSoqlQuery();

			cFilter.accountId = acct.Id;
			String criteria = cFilter.getCriteria();

			String sortString = cFilter.getSort();

			Integer resultSetSize = (cFilter.maxResults == null) ? APIUtils.MAX_LIST_RESULTS : (cFilter.maxResults < APIUtils.MAX_LIST_RESULTS) ? cFilter.maxResults : APIUtils.MAX_LIST_RESULTS;
			Integer resultOffset = (cFilter.offset == null) ? 0 : cFilter.offset;

			List<Case> returnedCases = CaseUtils.queryCases(fields, criteria, sortString, resultOffset, resultSetSize);

			if (returnedCases.isEmpty()) {
				result.cases = new List<APIUtils.APICase>();
			} else {
				Map<Id, Case_Comment__c> comments = new Map<Id, Case_Comment__c>();

				if (!cFilter.reduceInformation()) {
					if (cContext.isInternal) {
						comments = CaseCommentUtils.getMostRecentComments(returnedCases);
					} else {
						comments = CaseCommentUtils.getMostRecentPublicComments(returnedCases);
					}
				}

				for (Case c : returnedCases) {
					APIUtils.APICase apiCase = new APIUtils.APICase(c, cContext.isInternal);

					if (comments.containsKey(c.Id)) {
						apiCase.addComments(new List<Case_Comment__c> {comments.get(c.Id)});
					}

					if (caseToCommentMap.containsKey(c.Id)) {
						for (Case_Comment__c comment : caseToCommentMap.get(c.Id)) {
							Boolean canAccessComment = CaseUtils.canAccessComment(contact, comment, cContext.isInternal);
							Boolean isMostRecentComment = comments.containsKey(c.Id) && (comments.get(c.Id).Id == comment.Id);

							if (canAccessComment && !isMostRecentComment) {
								apiCase.addComment(comment);
							}
						}
					}

					result.addCase(apiCase);
				}
			}

			result.totalCaseCount = CaseUtils.getTotalCases(criteria);
			result.returnCode = APIUtils.STATUS_OK;
		} catch (GenericUtils.InvalidPermissionsException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_FORBIDDEN;
			result.message = e.getMessage();
		} catch (GenericUtils.InvalidException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_BAD;
			result.message = e.getMessage();
		} catch (GenericUtils.UnknownException e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.WARN);
			result.returnCode = APIUtils.STATUS_NOTFOUND;
			result.message = e.getMessage();
		} catch (Exception e) {
			GenericUtils.reportException(methodName, paramList, e, GenericUtils.ERROR);
			result.returnCode = APIUtils.STATUS_ISE;
			result.message = e.getMessage();
		} finally {
			logs.flush();
		}

		return result;
	}

