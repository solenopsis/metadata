	static testMethod void listOpenCasesContactTest() {
		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		String ssoName = TestUtils.getUniqueString('_unittest_contact: sso');
		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase1 = TestUtils.getCase(testAccount, testContact);
		insert testCase1;

		Case testCase2 = TestUtils.getCase(testAccount, testContact);
		insert testCase2;
		Boolean found1 = false;
		Boolean found2 = false;
		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);
		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();
		Test.startTest();

		APIUtils.APICases result =  CaseAPI.listCases(cContext, aContext, cFilter);
		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');

		for (APIUtils.APICase c : result.cases) {
			if (c.Id == testCase1.Id ) {
				found1 = true;
			} else if (c.Id == testCase2.Id ) {
				found2 = true;
			} else {
				System.assert(false, 'Got a case back we didn\'t expect Id = "'+c.Id+'"');
			}
		}

		Test.stopTest();

		System.assert(found1, 'Did not find the first case');
		System.assert(found2, 'Did not find the second case');
	}

