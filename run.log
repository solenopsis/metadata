/**
* This is test class for CaseAPI.addExternalCaseHandlingSystem method
*
* @author Sagar Shirke (sshirke@redhat.com)
*/

@isTest
private class CaseAPI_addExternalHandlingSystems_Test {
	@TestSetup
	static void setUp() {
		TestUtils.setupProductAndVersion();
	}

	static testMethod void addExternalCaseSystems_internal_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
		List<String> externalSystems = TestUtils.getActiveExternalSystems(1);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.addExternalCaseHandlingSystem(contactContext, caseContext, externalSystems);

		Test.stopTest();

		Set<String> expectedResults = new Set<String>(externalSystems);

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code ['+result.message+']');
		System.assertEquals(expectedResults.size(), result.externalCaseHandlingSystems.size(), 'Did not get the right number of external systems back');
		System.assert(result.handledByAscension, 'Handled by Ascension flag should have been set.');

		for (String externalSystem : result.externalCaseHandlingSystems) {
			if (!expectedResults.contains(externalSystem)) {
				System.assert(false, 'Got an external system we did not expect ['+externalSystem+']');
			}

			expectedResults.remove(externalSystem);
		}

		System.assert(expectedResults.isEmpty(), 'Did not get all the external systems back that we expected ['+expectedResults+']');

		testCase = TestUtils.fetchCase(testCase);

		System.assertEquals(GenericUtils.joinMultiselectList(externalSystems), testCase.External_Handling_System__c, 'Did not get the right information stored on the case');
	}

	static testMethod void addExternalCaseSystems_external_ignored() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
		List<String> externalSystems = TestUtils.getActiveExternalSystems(1);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.addExternalCaseHandlingSystem(contactContext, caseContext, externalSystems);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right return code ['+result.message+']');
		System.assertEquals(null, result.externalCaseHandlingSystems, 'Should not have added the external system.');
		System.assertEquals(null, result.handledByAscension, 'Handled by Ascension flag should be null for external contact.');
	}

	static testMethod void addExternalCaseSystems_unknownSystem_invalid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);
		List<String> externalSystems = new List<String>{'_unittest_external_system_: 001'};

		Test.startTest();

		APIUtils.APICase result = CaseAPI.addExternalCaseHandlingSystem(contactContext, caseContext, externalSystems);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_NOTFOUND, result.returnCode, 'Did not get the right return code ['+result.message+']');
		System.assertEquals(GenericUtils.MSG_INVALID_EXTERNAL_SYSTEM, result.message, 'Got the right code but the wrong message');
	}

