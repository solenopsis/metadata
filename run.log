	static testMethod void getCase_calls_internal_valid() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		User_Case_Contact__c testCaseContact = TestUtils.getCustomerCaseContact(testCase, testContact);
		insert testCaseContact;

		Task testCall1 = TestUtils.getCall(testCase);
		insert testCall1;

		TestUtils.waitAtLeastASecond();

		Task testCall2 = TestUtils.getCall(testCase);
		insert testCall2;

		APIUtils.ContactContext contactContext = new APIUtils.ContactContext(testContact);
		APIUtils.CaseContext caseContext = new APIUtils.CaseContext(testCase);

		Test.startTest();

		APIUtils.APICase result = CaseAPI.getCase(contactContext, caseContext);

		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the correct status code ['+result.message+']');

		List<Id> expectedResults = new List<Id>{
			testCall1.Id,
			testCall2.Id
		};

		System.assertEquals(expectedResults.size(), result.calls.size(), 'Did not get the expected number of calls back');

		for (Integer i = 0; i < result.calls.size(); i++) {
			System.assertEquals(expectedResults.get(i), result.calls.get(i).Id, 'Did not get the right call back in slot ' + i);
		}
	}

