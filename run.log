		System.assertEquals(testContact.Id, newComment.Created_By_Contact__c, 'Did not get the right created by');
		System.assertEquals(GenericUtils.WAITING_ON_RED_HAT_STATUS, newCase.Status, 'Did not get the right status back');
		System.assertEquals(GenericUtils.WAITING_ON_OWNER_ISTATUS, newCase.Internal_Status__c, 'Did not get the right internal status back');
		System.assertEquals(ONGOING_RESPONSE_MILESTONE_TARGET_DATE, newCase.TargetDate__c, 'Incorrect Target Date on the case');

		System.assertEquals(null, newNEP, 'Case should not have a NEP after being updated by customer contact');
	}

