		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		List<Case_Comment__c> testComments = new List<Case_Comment__c>();
		testComments.add(TestUtils.getPublicComment(testCase, commentBody1));
		testComments.add(TestUtils.getPrivateComment(testCase, commentBody2));
		testComments.add(TestUtils.getPublicComment(testCase, commentBody3));
		insert testComments;

		Map<String, Case_Comment__c> expectedResults = new Map<String, Case_Comment__c>();

		for (Case_Comment__c comment : testComments) {
