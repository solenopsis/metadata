	static testMethod void abandonCase_valid() {
		String ABANDONED_QUEUE_NAME = TestUtils.getUniqueString('Abandoned');
		GenericUtils.ABANDONED_QUEUE_NAME = ABANDONED_QUEUE_NAME;

		Group abandonedQueue = TestUtils.createCaseQueue(ABANDONED_QUEUE_NAME);

		String ssoName = TestUtils.getEmailAddress('example.com');
		String CASE_SUBJECT = 'Case Subject';

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		testAccount = TestUtils.fetchAccount(testAccount);

		Entitlement premiumEntitlement = TestUtils.getPremiumEntitlement(testAccount);
		insert premiumEntitlement;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case caseToAbandon = TestUtils.getCase(testAccount);
		caseToAbandon.Subject = CASE_SUBJECT;
		caseToAbandon.EntitlementId = premiumEntitlement.Id;
		caseToAbandon.ContactId = testContact.Id;
		insert caseToAbandon;

		caseToAbandon = TestUtils.fetchCase(caseToAbandon);

		APIUtils.ContactContext context = new APIUtils.ContactContext(testContact);
		APIUtils.APICase kase = new APIUtils.APICase(caseToAbandon, AccountUtils.isInternal(testContact));
		kase.summary = 'New Subject';
		kase.callingContact = testContact;
		kase.abandonCase = true;
		kase.CaseNumber = caseToAbandon.caseNumber;

		Test.startTest();
		kase = CaseAPI.updateCase(context, kase);
		Test.stopTest();

		System.assertEquals(APIUtils.STATUS_OK, kase.returnCode, 'Did not get the right return code [' + kase.message + ']');

		Case result = TestUtils.fetchCase(new Case(Id = kase.Id));

		System.assertEquals(null, result.AccountId, 'Did not get the right account back');
		System.assertEquals(null, result.ContactId, 'Did not get the right contact back');
		System.assertEquals(null, result.EntitlementId, 'Did not get the right entitlement back');
		System.assertEquals(abandonedQueue.Id, result.OwnerId, 'did not get the correct ownerId back');
		System.assertEquals(null, result.Case_Owner__c, 'Case owner should be set to null');
		System.assertEquals(testContact.Id, result.Last_Modified_By_Contact__c, 'Did not get correct Last_Modified_By_Contact__c back');
		System.assertEquals(testContact.Id, result.Last_Modified_By_Id__c, 'Did not get correct Last_Modified_By_Id__c back');
		// The Subject did not change (even though .summary was set above) because abandoning the Case does not permit any other updates
		System.assertEquals(CASE_SUBJECT, result.Subject, 'Subject should remain unchanged');
	}

