		insert testEntitlement;
		testEntitlement = TestUtils.fetchEntitlement(testEntitlement);

		System.assertNotEquals(null, sla.Id, 'We should have an SLA ID');
		System.assertNotEquals(null, testEntitlement.SlaProcessId, 'Process Id should not be null [Basic entitlement process should be active]');

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		Case testCase = TestUtils.getDefaultCase(testAccount);
		testCase.Status = GenericUtils.WAITING_ON_RED_HAT_STATUS;
		testCase.Internal_Status__c = GenericUtils.WAITING_ON_CUSTOMER_ISTATUS;
		testCase.Severity__c = GenericUtils.SEVERITY_THREE;
		testCase.FTS__c = true;
		testCase = TestUtils.setEntitlement(testCase, testEntitlement);
		testCase.BusinessHoursId = bh.Id;
		insert testCase;

		Case_Comment__c testUserComment = TestUtils.getPublicComment(testCase, '__unittest__userComment: 001');
		insert testUserComment;
		TestUtils.waitAtLeastASecond();

		List<CaseMilestone> milestones = TestUtils.getActiveCaseMilestones(testCase);
		System.assert(!milestones.isEmpty(), 'Should have milestones');

		CaseMilestone cm = TestUtils.getSpecificActiveMilestone(milestones, CaseMilestoneUtils.MILESTONE_TYPE_ONGOING_RESPONSE);
		DateTime initialStartDate = cm != null ? cm.StartDate : null;

		//Wait at least a three seconds
		for (Integer i = 0; i<3; i++) {
			TestUtils.waitAtLeastASecond();
		}

		Test.startTest();
		System.assertNotEquals(null, initialStartDate, 'Initial start date should not be null');
		//user increases severity from THREE to ONE.
		CaseTriggerAfter.TARGET_DATE_LOCK = false;
		testCase.Severity__c = GenericUtils.SEVERITY_ONE;
		update testCase;
		Test.stopTest();


		testCase = TestUtils.fetchCase(testCase);
		milestones = TestUtils.getActiveCaseMilestones(testCase);
		CaseMilestone ncm = TestUtils.getSpecificActiveMilestone(milestones, CaseMilestoneUtils.MILESTONE_TYPE_ONGOING_RESPONSE);
		DateTime newStartDate = ncm != null ? ncm.StartDate : null;

		System.assertNotEquals(null, newStartDate, 'Final start date should not be null');

		System.assertEquals(initialStartDate, newStartDate, 'Start Date should not have changed');
	}
}
