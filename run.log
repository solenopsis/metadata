	static testMethod void updateAttachmentMakePublicInternal_valid() {
		String testSsoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, testSsoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		Case testCase = TestUtils.getCase(testAccount);
		insert testCase;

		testCase = TestUtils.fetchCase(testCase);

		File_Attachment__c testAttachment = TestUtils.getPrivateAttachment(testCase);
		insert testAttachment;

		APIUtils.ContactContext testCContext = new APIUtils.ContactContext(testSsoName);
		APIUtils.APIAttachments apiAttachments = new APIUtils.APIAttachments();
		APIUtils.APIAttachment attachment = new APIUtils.APIAttachment();

		attachment.caseNumber = testCase.caseNumber;
		attachment.id = testAttachment.Id;
		attachment.isPrivate = false;
		apiAttachments.addAPIAttachment(attachment);

		DateTime now  = DateTime.now();
		Testutils.clearOutgoingMessages(now);

		APIUtils.APIAttachments result;

		System.runAs(UserUtils.getIGLIntegrationUser()) {
			Test.startTest();

			result = CaseAPI.updateAttachments(testCContext, apiAttachments);

			Test.stopTest();
		}

		System.assertEquals(ApiUtils.STATUS_OK, result.returnCode, 'Did not get expected returncode [' + result.message + ']');
		System.assertEquals(1, result.attachments.size(), 'We should have exactly one attachment returned.');
		File_Attachment__c fileAttachment = TestUtils.fetchAttachment(result.attachments.get(0).id);
		System.assert(!fileAttachment.Private__c, 'Attachment should not be private');
		System.assertEquals(testContact.Id, fileAttachment.Last_Modified_By_Contact__c, 'Attachment does not show as modified by expected contact');

		List<Outgoing_Message__c> messages = TestUtils.getOutgoingMessagesSince(now);
		System.assertEquals(MessageUtils.MESSAGE_TYPE_FILE_ATTACHMENT, messages.get(0).Type__c, 'Message had the wrong type');
		System.assertEquals(1, messages.size(), 'We should have sent exactly one message');
		FileAttachmentUtils.OutgoingMessage om = new FileAttachmentUtils.OutgoingMessage();
		FileAttachmentUtils.FileAttachmentEntry attachmentEntry = (FileAttachmentUtils.FileAttachmentEntry) JSON.deserialize(om.unmarshalJson(new List<Outgoing_Message__c> {messages.get(0)}), FileAttachmentUtils.FileAttachmentEntry.class);
		System.assertEquals(FileAttachmentUtils.ACTION_UPDATE, attachmentEntry.action, 'Did not get the expected action');
		System.assertEquals(testAttachment.UUID__c, attachmentEntry.attachment.UUID__c, 'Did not get the expected UUID');
	}

