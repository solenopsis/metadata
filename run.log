	static testMethod void listCasesInGroupInternalTest() {
		String ssoName = TestUtils.getUniqueString('_unittest_sso_: 001');

		Account testAccount = TestUtils.getAccount();
		insert testAccount;

		testAccount = TestUtils.fetchAccount(testAccount);

		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		testContact = TestUtils.makeContactInternal(testContact);
		insert testContact;

		CaseFolder__c cg = TestUtils.getGroup(testAccount,'Important Cases');
		insert cg;

		cg = TestUtils.fetchGroup(cg);

		Integer numberOfCasesToInsert = 6;
		Integer numberOfCasesInFolder = 3;

		List<Case> caseList = new List<Case>();
		Set<String> caseSubjectSet = new Set<String>();
		Set<String> caseSubjectInFolderSet = new Set<String>();
		for (Integer i = 0; i < numberOfCasesToInsert; i++){
			Case testCase = TestUtils.getDefaultCase(testAccount);
			String testSubject = 'This is a test Case: ' + String.valueOf(i);
			testCase.Subject = testSubject;

			if (i < numberOfCasesInFolder) {
				testCase.FolderId__c = cg.Id;
				caseSubjectInFolderSet.add(testSubject);
			}

			caseList.add(testCase);
			caseSubjectSet.add(testSubject);
		}

		insert caseList;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);

		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter();
		cFilter.groupNumber = cg.folder_number__c;

		Test.StartTest();

		APIUtils.APICases result =  CaseAPI.listCases(cContext, aContext, null);
		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.assertEquals(numberOfCasesToInsert, result.cases.size(),'Did not get all case back');

		for (APIUtils.APICase c : result.cases){
			System.assert(caseSubjectSet.contains(c.summary),'did not get the case summary');
		}

		result = CaseAPI.listCases(cContext, aContext,cFilter);
		System.assertEquals(numberOfCasesInFolder, result.cases.size(),'Did not get all case back from the Group');

		for (APIUtils.APICase c : result.cases){
			System.assert(caseSubjectInFolderSet.contains(c.summary),'did not get the case summary');
		}

		Test.stopTest();
	}

	static testMethod void listCasesInGroupAsContactTest() {
		// Makes it so all users/contacts are supported for purposes of testing
		Account testAccount = TestUtils.getAccount();
		testAccount.hasGroupACLs__c = false;
		insert testAccount;

		testAccount = TestUtils.fetchAccount(testAccount);

		String ssoName = TestUtils.getUniqueString('_unittest_contact: sso');
		Contact testContact = TestUtils.getContactWithSSOName(testAccount, ssoName);
		insert testContact;

		CaseFolder__c cg = TestUtils.getGroup(testAccount,'Important Cases');
		insert cg;
		cg = TestUtils.fetchGroup(cg);
		Integer numberOfCasesToInsert = 6;
		Integer numberOfCasesInFolder = 3;

		List<Case> caseList = new List<Case>();
		Set<String> caseSubjectSet = new Set<String>();
		Set<String> caseSubjectInFolderSet = new Set<String>();
		for (Integer i = 0; i < numberOfCasesToInsert; i++){
			Case testCase = TestUtils.getDefaultCase(testAccount);
			String testSubject = 'This is a test Case: ' + String.valueOf(i);
			testCase.Subject = testSubject;
			if (i < numberOfCasesInFolder){
				testCase.FolderId__c = cg.Id;
				caseSubjectInFolderSet.add(testSubject);
			}
				caseList.add(testCase);
				caseSubjectSet.add(testSubject);
		}

		insert caseList;

		APIUtils.ContactContext cContext = new APIUtils.ContactContext(testContact);

		APIUtils.AccountContext aContext = new APIUtils.AccountContext(testAccount);
		CaseAPI.CaseFilter cFilter = new CaseAPI.CaseFilter(cg.folder_number__c,null,null,null,null,null);
		cFilter.groupNumber = cg.folder_number__c;

		Test.StartTest();

		APIUtils.APICases result =  CaseAPI.listCases(cContext, aContext, null);
		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');
		System.assertEquals(numberOfCasesToInsert, result.cases.size(),'Did not get all case back');

		for (APIUtils.APICase c : result.cases) {
			System.assert(caseSubjectSet.contains(c.summary),'did not get the case summary');
		}

		result = CaseAPI.listCases(cContext, aContext, cFilter);
		System.assertEquals(APIUtils.STATUS_OK, result.returnCode, 'Did not get the right status back ['+result.message+']');

		System.debug(result);
		System.assertEquals(numberOfCasesInFolder, result.cases.size(),'Did not get all case back from the Group');

		for (APIUtils.APICase c : result.cases) {
			System.assert(caseSubjectInFolderSet.contains(c.summary),'did not get the case summary');
		}

		Test.stopTest();
	}

